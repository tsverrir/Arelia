<MudDialog>
    <DialogContent>
        <MudText Class="mb-3">@L["EndAssignment.ChooseEndDate"]</MudText>
        <MudDatePicker @bind-Date="EndDate" Label="@L["Common.EndDate"]" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Common.Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm"
                   Disabled="@(EndDate is null)">@L["Common.Confirm"]</MudButton>
    </DialogActions>
</MudDialog>

@inject ILocalizer L

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    public DateTime? EndDate { get; set; } = DateTime.Today;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(EndDate!.Value));
    private void Cancel() => MudDialog.Cancel();
}
