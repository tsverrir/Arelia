<MudDialog>
    <DialogContent>
        <MudText Class="mb-3">Choose the end date for this role assignment.</MudText>
        <MudDatePicker @bind-Date="EndDate" Label="End Date" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Confirm"
                   Disabled="@(EndDate is null)">Confirm</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    public DateTime? EndDate { get; set; } = DateTime.Today;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(EndDate!.Value));
    private void Cancel() => MudDialog.Cancel();
}
