@typeparam TItem

<MudMenu Icon="@Icons.Material.Filled.ViewColumn" Title="Choose Columns" AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight" Dense="true">
    @for (var i = 0; i < Columns.Count; i++)
    {
        var index = i;
        var col = Columns[index];
        <MudMenuItem>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudCheckBox T="bool" Value="col.Visible"
                             ValueChanged="@(v => ToggleColumn(index, v))"
                             Dense="true" Size="Size.Small" />
                <MudText Typo="Typo.body2" Style="flex:1;">@col.Title</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small"
                               Disabled="@(index == 0)"
                               OnClick="@(() => MoveColumn(index, -1))" />
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small"
                               Disabled="@(index == Columns.Count - 1)"
                               OnClick="@(() => MoveColumn(index, 1))" />
            </MudStack>
        </MudMenuItem>
    }
</MudMenu>

@code {
    [Parameter, EditorRequired]
    public List<ColumnDefinition<TItem>> Columns { get; set; } = [];

    [Parameter]
    public EventCallback OnColumnsChanged { get; set; }

    private async Task ToggleColumn(int index, bool visible)
    {
        Columns[index] = Columns[index] with { Visible = visible };
        await OnColumnsChanged.InvokeAsync();
    }

    private async Task MoveColumn(int index, int direction)
    {
        var target = index + direction;
        if (target < 0 || target >= Columns.Count) return;
        (Columns[target], Columns[index]) = (Columns[index], Columns[target]);
        await OnColumnsChanged.InvokeAsync();
    }
}
