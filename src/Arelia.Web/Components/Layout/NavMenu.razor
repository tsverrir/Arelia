@inject ILocalizer L
@inject Arelia.Web.Services.AdminHighlightService HighlightService

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">@L["Nav.Home"]</MudNavLink>
    <MudNavLink Href="/calendar" Icon="@Icons.Material.Filled.CalendarMonth">@L["Nav.Calendar"]</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavGroup Title="@L["Nav.Management"]" Icon="@Icons.Material.Filled.Settings" Expanded="false">
                <MudNavLink Href="/people" Icon="@Icons.Material.Filled.People">@L["Nav.People"]</MudNavLink>
                <MudNavLink Href="/semesters" Icon="@Icons.Material.Filled.DateRange">@L["Nav.Semesters"]</MudNavLink>
                <MudNavLink Href="/activities" Icon="@Icons.Material.Filled.Event">@L["Nav.Activities"]</MudNavLink>
                <MudNavLink Href="/roles" Icon="@Icons.Material.Filled.Badge">@L["Nav.Roles"]</MudNavLink>
                <MudNavLink Href="/finances" Icon="@Icons.Material.Filled.Payments">@L["Nav.Finances"]</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="@L["Nav.Admin"]" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="false">
                <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.ManageAccounts">@L["Nav.Users"]</MudNavLink>
                <MudNavLink Href="/admin/organizations" Icon="@Icons.Material.Filled.Business">@L["Nav.Organizations"]</MudNavLink>
                <MudNavLink Href="/admin/audit" Icon="@Icons.Material.Filled.History">@L["Nav.AuditLog"]</MudNavLink>
                <MudNavLink Href="/admin/backups" Icon="@Icons.Material.Filled.Backup">@L["Nav.Backups"]</MudNavLink>
                <MudNavLink Icon="@(HighlightService.ShowMissingTranslations ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                            OnClick="HighlightService.Toggle">
                    @L["Layout.HighlightMissing"]
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

