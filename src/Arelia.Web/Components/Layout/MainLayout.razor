@inherits LayoutComponentBase
@implements IDisposable
@inject Arelia.Web.Services.TenantService TenantService
@inject NavigationManager Navigation

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">Arelia</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudButton Color="Color.Inherit"
                           EndIcon="@Icons.Material.Filled.UnfoldMore"
                           OnClick="@(() => Navigation.NavigateTo("/select-organization"))">
                    @(TenantService.CurrentOrganizationId.HasValue
                        ? TenantService.CurrentOrganizationName
                        : "Select Organization")
                </MudButton>
                <NotificationBell />
                <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                    <MudMenuItem Href="/Account/Manage">Profile</MudMenuItem>
                    <MudMenuItem>
                        <form method="post" action="/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="" />
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text"
                                       Color="Color.Default" FullWidth="true" Class="justify-start">
                                Sign out
                            </MudButton>
                        </form>
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Color="Color.Inherit">Sign in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    protected override async Task OnInitializedAsync()
    {
        TenantService.OnTenantChanged += StateHasChanged;
        await TenantService.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await TenantService.TryRestoreFromStorageAsync();
    }

    public void Dispose()
    {
        TenantService.OnTenantChanged -= StateHasChanged;
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
