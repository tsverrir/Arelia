@inherits LayoutComponentBase
@implements IDisposable
@inject Arelia.Web.Services.TenantService TenantService
@inject Arelia.Web.Services.CultureService CultureService
@inject Arelia.Web.Services.AdminHighlightService HighlightService
@inject Arelia.Web.Services.UiSkinService SkinService
@inject Arelia.Web.Services.NavigationHistoryService NavigationHistory
@inject ILocalizer L
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="@SkinService.CurrentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (HighlightService.ShowMissingTranslations)
{
    <style>.missing-translation { outline: 2px solid red; outline-offset: 1px; }</style>
}

<MudLayout Class="@ShellClass">
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <AppBackButton />
        <MudText Typo="Typo.h6" Class="ml-3">@L["Layout.AppName"]</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <SkinSwitcher />
        </MudHidden>
        <AuthorizeView>
            <Authorized>
                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudButton Color="Color.Inherit"
                               EndIcon="@Icons.Material.Filled.UnfoldMore"
                               OnClick="@(() => Navigation.NavigateTo("/select-organization"))">
                        @(TenantService.CurrentOrganizationId.HasValue
                            ? TenantService.CurrentOrganizationName
                            : L["Layout.SelectOrganization"])
                    </MudButton>
                </MudHidden>
                <MudHidden Breakpoint="Breakpoint.MdAndUp">
                    <MudIconButton Icon="@Icons.Material.Filled.Business"
                                   Color="Color.Inherit"
                                   aria-label="@L["Layout.SelectOrganization"]"
                                   OnClick="@(() => Navigation.NavigateTo("/select-organization"))" />
                </MudHidden>
                <NotificationBell />
                <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit">
                    <MudMenuItem Href="/Account/Manage">@L["Layout.Profile"]</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Language" Disabled="true">@L["Common.Language"]</MudMenuItem>
                    @foreach (var (code, label) in _languages)
                    {
                        var isCurrent = string.Equals(code, CultureService.CurrentCultureName, StringComparison.OrdinalIgnoreCase);
                        <MudMenuItem Icon="@(isCurrent ? Icons.Material.Filled.Check : Icons.Material.Filled.Circle)"
                                     IconColor="@(isCurrent ? Color.Primary : Color.Transparent)"
                                     OnClick="@(() => SetLanguageAsync(code))">@label</MudMenuItem>
                    }
                    <MudDivider />
                    <MudMenuItem>
                        <form method="post" action="/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="" />
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text"
                                       Color="Color.Default" FullWidth="true" Class="justify-start">
                                @L["Layout.SignOut"]
                            </MudButton>
                        </form>
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Color="Color.Inherit">@L["Layout.SignIn"]</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private string ShellClass => $"arelia-shell {SkinService.CurrentSkin.CssClass}";

    private static readonly (string Code, string Label)[] _languages =
    [
        ("en", "English"),
        ("da", "Dansk"),
        ("is", "Íslenska"),
    ];

    protected override async Task OnInitializedAsync()
    {
        TenantService.OnTenantChanged += OnTenantOrHighlightChanged;
        HighlightService.OnChanged += OnTenantOrHighlightChanged;
        SkinService.OnSkinChanged += OnTenantOrHighlightChanged;
        NavigationHistory.Initialize();
        await TenantService.InitializeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await TenantService.TryRestoreFromStorageAsync();
        await SkinService.TryInitializeAsync();
        await CultureService.TryInitializeAsync();
    }

    private async Task SetLanguageAsync(string code)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is not null)
            await CultureService.SetCultureAsync(userId, code);
    }

    private void OnTenantOrHighlightChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TenantService.OnTenantChanged -= OnTenantOrHighlightChanged;
        HighlightService.OnChanged -= OnTenantOrHighlightChanged;
        SkinService.OnSkinChanged -= OnTenantOrHighlightChanged;
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}

