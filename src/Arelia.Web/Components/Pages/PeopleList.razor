@page "/people"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Interfaces
@using Arelia.Application.Organizations.Commands
@using Arelia.Application.People.Commands
@using Arelia.Application.People.Queries
@using Arelia.Domain.Enums
@using Arelia.Web.Components.Shared
@using MediatR
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["People.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("People.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
    return;
}

<MudStack Row="true" Class="mb-4" AlignItems="AlignItems.End" Spacing="3">
    <MudTextField @bind-Value="_searchTerm" Label="@L["Common.Search"]" Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                  TextChanged="OnSearchChanged" />
    <MudSelect T="VoiceGroup?" Value="_voiceGroupFilter" Label="@L["Common.VoiceGroup"]" Clearable="true"
               ValueChanged="@(async (VoiceGroup? v) => { _voiceGroupFilter = v; await LoadPeople(); })">
        @foreach (var vg in Enum.GetValues<VoiceGroup>())
        {
            <MudSelectItem T="VoiceGroup?" Value="@vg">@VoiceGroupLabel(vg)</MudSelectItem>
        }
    </MudSelect>
    <MudCheckBox T="bool" Value="_showInactive" Label="@L["People.ShowInactive"]"
                 ValueChanged="@(async (bool v) => { _showInactive = v; await LoadPeople(); })" />
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@(() => _showAddByEmail = true)"
               StartIcon="@Icons.Material.Filled.PersonSearch">
        @L.H("People.AddByEmail")
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="@(() => _showImport = true)"
               StartIcon="@Icons.Material.Filled.TransferWithinAStation">
        @L.H("People.ImportFromOrg")
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _showCreate = true)"
               StartIcon="@Icons.Material.Filled.PersonAdd">
        @L.H("People.AddPerson")
    </MudButton>
</MudStack>

@if (_people is not null)
{
    <ConfigurableTable TItem="PersonListDto" Items="_people" Columns="_columns" OnRowClick="OnRowClick">
        <CellTemplate>
            @switch (context.ColumnKey)
            {
                case "VoiceGroup":
                    @VoiceGroupLabel((VoiceGroup?)context.Value)
                    break;
                case "Status":
                    <MudChip T="string" Size="Size.Small" Color="@((bool)(context.Value ?? false) ? Color.Success : Color.Default)">
                        @((bool)(context.Value ?? false) ? L["Common.Active"] : L["Common.Inactive"])
                    </MudChip>
                    break;
                default:
                    @(context.Value?.ToString() ?? "—")
                    break;
            }
        </CellTemplate>
    </ConfigurableTable>
}

<MudDialog @bind-Visible="_showCreate">
    <TitleContent><MudText Typo="Typo.h6">@L.H("People.AddPersonTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_firstName" Label="@L["Common.FirstName"]" Required="true" />
        <MudTextField @bind-Value="_lastName" Label="@L["Common.LastName"]" Required="true" />
        <MudTextField @bind-Value="_email" Label="@L["Common.Email"]" />
        <MudTextField @bind-Value="_phone" Label="@L["Common.Phone"]" />
        <MudSelect T="VoiceGroup?" @bind-Value="_voiceGroup" Label="@L["Common.VoiceGroup"]" Clearable="true">
            @foreach (var vg in Enum.GetValues<VoiceGroup>())
            {
                <MudSelectItem T="VoiceGroup?" Value="@vg">@VoiceGroupLabel(vg)</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_notes" Label="@L["Common.Notes"]" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreate = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreatePerson">@L.H("Common.Create")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showAddByEmail">
    <TitleContent><MudText Typo="Typo.h6">@L.H("People.AddByEmailTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteEmail" Label="@L["Common.Email"]" Required="true" />
        <MudTextField @bind-Value="_inviteFirstName" Label="@L["Common.FirstName"]" />
        <MudTextField @bind-Value="_inviteLastName" Label="@L["Common.LastName"]" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showAddByEmail = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddByEmail">@L.H("Common.Add")</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showImport">
    <TitleContent><MudText Typo="Typo.h6">@L.H("People.ImportFromOrgTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_importSearch" Label="@L["People.ImportSearch"]" Immediate="true"
                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                      TextChanged="OnImportSearchChanged" />
        @if (_importResults is not null)
        {
            @if (_importResults.Count == 0)
            {
                <MudText Class="mt-2" Color="Color.Secondary">@L["People.ImportNoResults"]</MudText>
            }
            else
            {
                <MudTable Items="_importResults" Dense="true" Hover="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>@L["Common.Name"]</MudTh>
                        <MudTh>@L["Common.Organization"]</MudTh>
                        <MudTh>@L["Common.Email"]</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.FirstName @context.LastName</MudTd>
                        <MudTd>@context.OrganizationName</MudTd>
                        <MudTd>@context.Email</MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                       OnClick="@(() => ImportPerson(context))">@L["People.ImportBtn"]</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImportDialog">@L.H("Common.Cancel")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<PersonListDto>? _people;
    private string _searchTerm = string.Empty;
    private VoiceGroup? _voiceGroupFilter;
    private bool _showInactive;
    private bool _showCreate;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _email;
    private string? _phone;
    private VoiceGroup? _voiceGroup;
    private string? _notes;

    private List<ColumnDefinition<PersonListDto>>? _columns;

    private bool _showAddByEmail;
    private string _inviteEmail = string.Empty;
    private string? _inviteFirstName;
    private string? _inviteLastName;

    private bool _showImport;
    private string _importSearch = string.Empty;
    private List<PersonAcrossOrgDto>? _importResults;

    protected override async Task OnInitializedAsync()
    {
        _columns =
        [
            new("FirstName", L["Common.FirstName"], x => x.FirstName, SortBy: x => x.FirstName),
            new("LastName", L["Common.LastName"], x => x.LastName, SortBy: x => x.LastName),
            new("Email", L["Common.Email"], x => x.Email),
            new("Phone", L["Common.Phone"], x => x.Phone),
            new("VoiceGroup", L["Common.VoiceGroup"], x => x.VoiceGroup),
            new("Status", L["Common.Status"], x => x.IsActive),
        ];
        RegisterTenantChangeHandler();
        await LoadPeople();
    }

    protected override Task OnTenantChangedAsync() => LoadPeople();

    private async Task LoadPeople()
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;
        _people = await Mediator.Send(new GetPeopleQuery(
            orgId, _voiceGroupFilter,
            _showInactive ? null : true,
            string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm));
    }

    private async Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        await LoadPeople();
    }

    private void OnRowClick(TableRowClickEventArgs<PersonListDto> args)
    {
        Navigation.NavigateTo($"/people/{args.Item!.Id}");
    }

    private async Task CreatePerson()
    {
        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
        {
            Snackbar.Add(L["People.NameRequired"], Severity.Warning);
            return;
        }
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        var existing = await Mediator.Send(new GetPeopleQuery(orgId));
        var isDuplicate = existing.Any(p =>
            string.Equals(p.FirstName.Trim(), _firstName.Trim(), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(p.LastName.Trim(), _lastName.Trim(), StringComparison.OrdinalIgnoreCase));

        if (isDuplicate)
        {
            var dlgParams = new DialogParameters<ConfirmDialog>
            {
                { x => x.ContentText, string.Format(L["People.DuplicateConfirm"], _firstName, _lastName) }
            };
            var dlg = await DialogService.ShowAsync<ConfirmDialog>(L["People.DuplicateTitle"], dlgParams);
            var dlgResult = await dlg.Result;
            if (dlgResult is null || dlgResult.Canceled) return;
        }
        else
        {
            // Check for matching persons in other organizations
            var crossOrgMatches = await Mediator.Send(
                new FindPersonsAcrossOrgsQuery($"{_firstName} {_lastName}".Trim(), orgId));
            var exactMatches = crossOrgMatches
                .Where(p =>
                    string.Equals(p.FirstName.Trim(), _firstName.Trim(), StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(p.LastName.Trim(), _lastName.Trim(), StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (exactMatches.Count > 0)
            {
                var match = exactMatches[0];
                var dlgParams = new DialogParameters<ConfirmDialog>
                {
                    { x => x.ContentText,
                      string.Format(L["People.CrossOrgFound"], _firstName, _lastName, match.OrganizationName) }
                };
                var dlg = await DialogService.ShowAsync<ConfirmDialog>(L["People.CrossOrgTitle"], dlgParams);
                var dlgResult = await dlg.Result;
                if (dlgResult is not null && !dlgResult.Canceled)
                {
                    // Copy details from the matched person
                    _email ??= match.Email;
                    _phone ??= match.Phone;
                    _voiceGroup ??= match.VoiceGroup;
                }
                // If canceled, the user will fill in details manually — fall through to create
            }
        }

        var id = await Mediator.Send(new CreatePersonCommand(
            _firstName, _lastName, _email, _phone, _voiceGroup, _notes, orgId));

        Snackbar.Add(L["People.Created"], Severity.Success);
        _showCreate = false;
        _firstName = string.Empty;
        _lastName = string.Empty;
        _email = null;
        _phone = null;
        _voiceGroup = null;
        _notes = null;
        await LoadPeople();
    }

    private async Task AddByEmail()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail))
        {
            Snackbar.Add(L["People.EmailRequired"], Severity.Warning);
            return;
        }
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        var result = await Mediator.Send(new InviteUserCommand(
            _inviteEmail, orgId, _inviteFirstName, _inviteLastName));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["People.MemberAdded"], Severity.Success);
            _showAddByEmail = false;
            _inviteEmail = string.Empty;
            _inviteFirstName = null;
            _inviteLastName = null;
            await LoadPeople();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task OnImportSearchChanged(string value)
    {
        _importSearch = value;
        if (string.IsNullOrWhiteSpace(value) || TenantService.CurrentOrganizationId is not Guid orgId)
        {
            _importResults = null;
            return;
        }
        _importResults = await Mediator.Send(new FindPersonsAcrossOrgsQuery(value, orgId));
    }

    private async Task ImportPerson(PersonAcrossOrgDto source)
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        await Mediator.Send(new CreatePersonCommand(
            source.FirstName, source.LastName, source.Email, source.Phone,
            source.VoiceGroup, null, orgId));

        Snackbar.Add(string.Format(L["People.Imported"], source.FirstName, source.LastName), Severity.Success);
        CloseImportDialog();
        await LoadPeople();
    }

    private void CloseImportDialog()
    {
        _showImport = false;
        _importSearch = string.Empty;
        _importResults = null;
    }

    private string VoiceGroupLabel(VoiceGroup? vg) => vg switch
    {
        null => "—",
        VoiceGroup.None => L["People.VoiceGroupNone"],
        _ => vg.ToString()!
    };
}
