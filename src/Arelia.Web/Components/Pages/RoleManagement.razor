@page "/roles"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Roles.Commands
@using Arelia.Application.Roles.Queries
@using Arelia.Domain.Enums
@using Arelia.Web.Components.Shared
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Roles.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Roles.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
    return;
}

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _showCreate = true)"
           StartIcon="@Icons.Material.Filled.Add" Class="mb-4">
    @L.H("Roles.Create")
</MudButton>

@if (_roles is not null)
{
    <MudText Typo="Typo.h6" Class="mt-4 mb-2">@L.H("Roles.PermissionMatrix")</MudText>
    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
        The <strong>Admin</strong> role always has full access — its permissions cannot be edited.
        <strong>Board</strong> and <strong>Member</strong> are system roles with editable permissions.
    </MudAlert>

    <MudSimpleTable Dense="true" Hover="true" Style="overflow-x: auto;">
        <thead>
            <tr>
                <th>@L["Common.Permission"]</th>
                @foreach (var role in _roles.Where(r => r.IsActive))
                {
                    <th style="text-align:center;">
                        @role.Name
                        @if (role.RoleType != RoleType.Custom)
                        {
                            <MudChip T="string" Size="Size.Small" Color="@RoleTypeColor(role.RoleType)"
                                     Class="ml-1" Style="height:18px;font-size:10px;">
                                @role.RoleType
                            </MudChip>
                        }
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var permission in Enum.GetValues<Permission>())
            {
                <tr>
                    <td>@permission</td>
                    @foreach (var role in _roles.Where(r => r.IsActive))
                    {
                        var hasPermission = role.RoleType == RoleType.Admin || role.Permissions.Contains(permission);
                        var isEditable = role.RoleType != RoleType.Admin;
                        <td style="text-align:center;">
                            <MudCheckBox T="bool" Value="hasPermission"
                                         ValueChanged="@(v => OnPermissionToggle(role.Id, permission, v))"
                                         Disabled="@(!isEditable)" />
                        </td>
                    }
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    <MudText Typo="Typo.h6" Class="mt-6 mb-2">@L.H("Roles.AllRoles")</MudText>
    <ConfigurableTable TItem="RoleDto" Items="_roles" Columns="_roleColumns" OnRowClick="OnRoleRowClick">
        <CellTemplate>
            @switch (context.ColumnKey)
            {
                case "Status":
                    <MudChip T="string" Size="Size.Small" Color="@((bool)(context.Value ?? false) ? Color.Success : Color.Default)">
                        @((bool)(context.Value ?? false) ? L["Common.Active"] : L["Common.Inactive"])
                    </MudChip>
                    break;
                case "Type":
                    var roleType = (RoleType)(context.Value ?? RoleType.Custom);
                    <MudChip T="string" Size="Size.Small" Color="@RoleTypeColor(roleType)">@roleType</MudChip>
                    break;
                default:
                    @(context.Value?.ToString() ?? "—")
                    break;
            }
        </CellTemplate>
    </ConfigurableTable>
}

<MudDialog @bind-Visible="_showCreate">
    <TitleContent><MudText Typo="Typo.h6">@L.H("Roles.CreateTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newRoleName" Label="@L["Roles.RoleName"]" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreate = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateRole">@L.H("Common.Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<RoleDto>? _roles;
    private List<RoleDto>? _customRoles;
    private bool _showCreate;
    private string _newRoleName = string.Empty;

    private List<ColumnDefinition<RoleDto>>? _roleColumns;

    protected override async Task OnInitializedAsync()
    {
        _roleColumns =
        [
            new("Name", L["Common.Name"], x => x.Name),
            new("Type", "Type", x => x.RoleType),
            new("Assignments", L["Roles.ActiveAssignments"], x => x.AssignmentCount),
            new("Status", L["Common.Status"], x => x.IsActive),
        ];
        RegisterTenantChangeHandler();
        await LoadRoles();
    }

    private static Color RoleTypeColor(RoleType roleType) => roleType switch
    {
        RoleType.Admin => Color.Error,
        RoleType.Board => Color.Warning,
        RoleType.Member => Color.Primary,
        _ => Color.Default,
    };

    protected override Task OnTenantChangedAsync() => LoadRoles();

    private async Task LoadRoles()
    {
        if (TenantService.CurrentOrganizationId is Guid orgId)
        {
            _roles = await Mediator.Send(new GetRolesQuery(orgId));
            _customRoles = _roles.Where(r => r.RoleType == RoleType.Custom).ToList();
        }
    }

    private void OnRoleRowClick(TableRowClickEventArgs<RoleDto> args)
    {
        Navigation.NavigateTo($"/roles/{args.Item!.Id}");
    }

    private async Task CreateRole()
    {
        if (string.IsNullOrWhiteSpace(_newRoleName))
        {
            Snackbar.Add("Role name is required.", Severity.Warning);
            return;
        }

        if (TenantService.CurrentOrganizationId is not Guid orgId)
            return;

        var result = await Mediator.Send(new CreateRoleCommand(_newRoleName, orgId));
        if (result.IsSuccess)
        {
            Snackbar.Add(string.Format(L["Roles.RoleCreated"], _newRoleName), Severity.Success);
            _showCreate = false;
            _newRoleName = string.Empty;
            await LoadRoles();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task OnPermissionToggle(Guid roleId, Permission permission, bool grant)
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        await Mediator.Send(new ToggleRolePermissionCommand(roleId, permission, grant, orgId));
        await LoadRoles();
    }
}
