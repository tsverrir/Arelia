@page "/calendar"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Activities.Queries
@using Arelia.Domain.Enums
@using MediatR
@using System.Globalization
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Calendar.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Calendar.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
    return;
}

@if (_activities is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Row="true" Class="mb-4" Spacing="2">
        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="PreviousMonth" />
        <MudText Typo="Typo.h6">@_currentMonth.ToString("MMMM yyyy")</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NextMonth" />
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" OnClick="GoToToday">@L.H("Calendar.Today")</MudButton>
    </MudStack>

    <div class="cal-container">
        <div class="cal-header">
            <div></div>
            @foreach (var name in GetLocalizedDayNames())
            {
                <div class="cal-header-cell">@name</div>
            }
        </div>

        @foreach (var weekData in GetWeeksData())
        {
            var numLanes = weekData.SpanningEvents.Count == 0 ? 0 : weekData.SpanningEvents.Max(e => e.Lane) + 1;
            var dayCellRow = numLanes + 2;
            var gridRows = numLanes == 0
                ? "24px minmax(60px, auto)"
                : $"24px {string.Join(" ", Enumerable.Repeat("22px", numLanes))} minmax(60px, auto)";

            <div class="cal-week" style="grid-template-rows: @gridRows;">

                <div class="cal-week-label" style="grid-column: 1; grid-row: 1;">
                    CW @ISOWeek.GetWeekOfYear(weekData.Days[0])
                </div>

                @for (int d = 0; d < 7; d++)
                {
                    var hDay = weekData.Days[d];
                    var hCol = d + 2;
                    var hClass = "cal-day-header" + (hDay.Date == DateTime.Today ? " cal-today" : "") + (hDay.Month == _currentMonth.Month ? "" : " cal-other-month");
                    <div class="@hClass" style="grid-column: @hCol; grid-row: 1;">@hDay.Day</div>
                }

                @* Background column cells for spanning rows — rendered before event bars so bars appear on top *@
                @if (numLanes > 0)
                {
                    <div style="grid-column: 1; grid-row: 2 / @(numLanes + 2);"></div>
                    @for (int d = 0; d < 7; d++)
                    {
                        var bgCol = d + 2;
                        <div class="cal-span-bg" style="grid-column: @bgCol; grid-row: 2 / @(numLanes + 2);"></div>
                    }
                }

                @* Spanning event bars *@
                @foreach (var se in weekData.SpanningEvents)
                {
                    var barColStart = se.ColStart + 2;
                    var barColEnd = se.ColEnd + 3;
                    var barRow = se.Lane + 2;
                    <div class="cal-event-bar"
                         style="grid-column: @barColStart / @barColEnd; grid-row: @barRow; background-color: @GetCssColor(se.Activity.ActivityType);"
                         @onclick="@(() => Navigation.NavigateTo($"/activities/{se.Activity.Id}"))">
                        @se.Activity.Name
                    </div>
                }

                <div class="cal-week-cell-col" style="grid-column: 1; grid-row: @dayCellRow;"></div>

                @* Day cells with single-day events *@
                @for (int d = 0; d < 7; d++)
                {
                    var cDay = weekData.Days[d];
                    var cCol = d + 2;
                    var cClass = "cal-day-cell" + (cDay.Month == _currentMonth.Month ? "" : " cal-other-month");
                    var cEvents = weekData.DayEvents[d];
                    <div class="@cClass" style="grid-column: @cCol; grid-row: @dayCellRow;">
                        @foreach (var act in cEvents)
                        {
                            <div class="cal-event-chip"
                                 style="background-color: @GetCssColor(act.ActivityType);"
                                 @onclick="@(() => Navigation.NavigateTo($"/activities/{act.Id}"))">
                                @if (act.StartDateTime.TimeOfDay != TimeSpan.Zero)
                                {
                                    <span>@act.StartDateTime.ToString("HH:mm") </span>
                                }
                                @act.Name
                            </div>
                        }
                    </div>
                }

            </div>
        }
    </div>
}

@code {
    private List<ActivityListDto>? _activities;
    private DateTime _currentMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);

    private record SpanningEventBar(ActivityListDto Activity, int ColStart, int ColEnd, int Lane);
    private record WeekData(List<DateTime> Days, List<SpanningEventBar> SpanningEvents, List<List<ActivityListDto>> DayEvents);

    protected override async Task OnInitializedAsync()
    {
        RegisterTenantChangeHandler();
        await LoadActivities();
    }

    protected override Task OnTenantChangedAsync() => LoadActivities();

    private async Task LoadActivities()
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;
        // Load without year filter so cross-month navigation at year boundaries works
        _activities = await Mediator.Send(new GetActivitiesQuery(orgId));
    }

    private async Task PreviousMonth()
    {
        _currentMonth = _currentMonth.AddMonths(-1);
        await LoadActivities();
    }

    private async Task NextMonth()
    {
        _currentMonth = _currentMonth.AddMonths(1);
        await LoadActivities();
    }

    private async Task GoToToday()
    {
        _currentMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
        await LoadActivities();
    }

    private List<List<DateTime>> GetWeeks()
    {
        var weeks = new List<List<DateTime>>();
        var firstDay = _currentMonth;
        var startDay = firstDay.AddDays(-(((int)firstDay.DayOfWeek + 6) % 7));
        var lastDay = _currentMonth.AddMonths(1).AddDays(-1);
        var endDay = lastDay.AddDays((7 - (int)lastDay.DayOfWeek) % 7);

        var current = startDay;
        while (current <= endDay)
        {
            var week = new List<DateTime>();
            for (int i = 0; i < 7; i++)
            {
                week.Add(current);
                current = current.AddDays(1);
            }
            weeks.Add(week);
        }
        return weeks;
    }

    private List<WeekData> GetWeeksData()
    {
        var result = new List<WeekData>();
        foreach (var week in GetWeeks())
        {
            var spanningActivities = new List<ActivityListDto>();
            var dayCellEvents = Enumerable.Range(0, 7).Select(_ => new List<ActivityListDto>()).ToList();

            foreach (var act in _activities!)
            {
                if (act.EndDateTime.Date > act.StartDateTime.Date)
                {
                    // Multi-day event: include if it overlaps this week
                    if (act.EndDateTime.Date >= week[0] && act.StartDateTime.Date <= week[6])
                        spanningActivities.Add(act);
                }
                else
                {
                    // Single-day event: place in its day cell
                    var dayIdx = (act.StartDateTime.Date - week[0]).Days;
                    if (dayIdx >= 0 && dayIdx < 7)
                        dayCellEvents[dayIdx].Add(act);
                }
            }

            // Sort by start date, then longest first for better packing
            spanningActivities.Sort((a, b) =>
            {
                int cmp = a.StartDateTime.Date.CompareTo(b.StartDateTime.Date);
                return cmp != 0 ? cmp : (b.EndDateTime - b.StartDateTime).CompareTo(a.EndDateTime - a.StartDateTime);
            });

            // Greedy lane-packing: assign each event to the first lane where it fits
            var laneEndCols = new List<int>();
            var eventBars = new List<SpanningEventBar>();

            foreach (var act in spanningActivities)
            {
                int colStart = Math.Max(0, (act.StartDateTime.Date - week[0]).Days);
                int colEnd = Math.Min(6, (act.EndDateTime.Date - week[0]).Days);

                int lane = -1;
                for (int i = 0; i < laneEndCols.Count; i++)
                {
                    if (laneEndCols[i] < colStart)
                    {
                        lane = i;
                        break;
                    }
                }

                if (lane == -1)
                {
                    lane = laneEndCols.Count;
                    laneEndCols.Add(colEnd);
                }
                else
                {
                    laneEndCols[lane] = colEnd;
                }

                eventBars.Add(new SpanningEventBar(act, colStart, colEnd, lane));
            }

            result.Add(new WeekData(week, eventBars, dayCellEvents));
        }
        return result;
    }

    private static string[] GetLocalizedDayNames()
    {
        var names = CultureInfo.CurrentUICulture.DateTimeFormat.AbbreviatedDayNames;
        // Reorder from Sun-first (0=Sun) to Mon-first (0=Mon)
        return [names[1], names[2], names[3], names[4], names[5], names[6], names[0]];
    }

    private static string GetCssColor(ActivityType type) => type switch
    {
        ActivityType.Semester => "var(--arelia-calendar-semester)",
        ActivityType.Rehearsal => "var(--arelia-calendar-rehearsal)",
        ActivityType.Concert => "var(--arelia-calendar-concert)",
        ActivityType.Trip => "var(--arelia-calendar-trip)",
        ActivityType.Social => "var(--arelia-calendar-social)",
        _ => "var(--arelia-calendar-other)",
    };
}
