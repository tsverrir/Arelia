@page "/activities/{ActivityId:guid}"
@using Arelia.Application.Activities.Commands
@using Arelia.Application.Activities.Queries
@using Arelia.Application.Attendance.Commands
@using Arelia.Application.Attendance.Queries
@using Arelia.Application.Rsvp.Commands
@using Arelia.Domain.Enums
@using MediatR
@using Microsoft.AspNetCore.Components.Forms
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@inject Arelia.Web.Services.TenantService TenantService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@(_activity?.Name ?? (_notFound ? "Activity not found" : L["ActivityDetail.BackToActivities"]))</PageTitle>

@if (_notFound)
{
    <BackButton DefaultHref="/activities" Label="@L["ActivityDetail.BackToActivities"]" />
    <MudAlert Severity="Severity.Warning" Class="mt-4">Activity not found.</MudAlert>
    return;
}

@if (_activity is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<MudStack Row="true" Class="mb-2" AlignItems="AlignItems.Center">
    <BackButton DefaultHref="@ActivityBackFallback" Label="@ActivityBackLabel" />
    <MudSpacer />
    @if (_activity.Status != ActivityStatus.Published)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="@(() => SetStatus(ActivityStatus.Published))"
                   StartIcon="@Icons.Material.Filled.Publish">
            Publish
        </MudButton>
    }
    @if (_activity.Status != ActivityStatus.Cancelled)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => SetStatus(ActivityStatus.Cancelled))"
                   StartIcon="@Icons.Material.Filled.Cancel">
            Cancel
        </MudButton>
    }
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="StartEdit"
               StartIcon="@Icons.Material.Filled.Edit">
        @L.H("Common.Edit")
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteActivity"
               StartIcon="@Icons.Material.Filled.Delete">
        @L.H("Common.Delete")
    </MudButton>
</MudStack>

<MudText Typo="Typo.h5" GutterBottom="true">@_activity.Name</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudCard>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudStack Row="true" Spacing="2">
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">@_activity.ActivityType</MudChip>
                        <MudChip T="string" Color="@GetActivityStatusColor(_activity.Status)" Size="Size.Small">@_activity.Status</MudChip>
                        <MudChip T="string" Size="Size.Small">@L["Common.WorkYear"] @_activity.WorkYear</MudChip>
                        @if (_activity.IsPublicVisible)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">@L["Common.Public"]</MudChip>
                        }
                    </MudStack>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                        <MudText>@_activity.StartDateTime.ToString("ddd dd MMM yyyy HH:mm") — @_activity.EndDateTime.ToString("ddd dd MMM yyyy HH:mm")</MudText>
                    </MudStack>

                    @if (!string.IsNullOrEmpty(_activity.Location))
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                            <MudText>@_activity.Location</MudText>
                        </MudStack>
                    }

                    @if (_activity.ParentName is not null)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                            <MudLink Href="@($"/semesters/{_activity.ParentActivityId}")">@_activity.ParentName</MudLink>
                        </MudStack>
                    }

                    @if (!string.IsNullOrEmpty(_activity.Description))
                    {
                        <MudDivider Class="my-2" />
                        <MudText>@_activity.Description</MudText>
                    }
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.H("ActivityDetail.Summary")</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (_activity.IsImplicitParticipation)
                {
                    <MudText>@string.Format(L["ActivityDetail.ParticipantsAll"], _activity.ParticipantCount)</MudText>
                }
                else if (_activity.MaxCapacity.HasValue)
                {
                    <MudText>@string.Format(L["ActivityDetail.Capacity"], _activity.ConfirmedCount, _activity.MaxCapacity)</MudText>
                }
                else
                {
                    <MudText>@string.Format(L["ActivityDetail.Participants"], _activity.ParticipantCount)</MudText>
                }
                @if (_activity.ChildActivityCount > 0)
                {
                    <MudText>@string.Format(L["ActivityDetail.ChildActivities"], _activity.ChildActivityCount)</MudText>
                }
                @if (_activity.RsvpEnabled || _activity.RsvpYesCount + _activity.RsvpNoCount + _activity.RsvpMaybeCount > 0)
                {
                    <MudDivider Class="my-2" />
                    <MudText>RSVP: @_activity.RsvpYesCount yes / @_activity.RsvpNoCount no / @_activity.RsvpMaybeCount maybe</MudText>
                    <MudText>Waiting list: @_activity.WaitlistCount</MudText>
                    <MudText>Waiting list enabled: @(_activity.WaitingListEnabled ? "Yes" : "No")</MudText>
                }
                @if (_activity.SignupDeadline.HasValue)
                {
                    <MudText>@string.Format(L["ActivityDetail.SignupDeadline"], _activity.SignupDeadline.Value.ToString("dd MMM yyyy HH:mm"))</MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@if (!_activity.IsImplicitParticipation)
{
    <MudCard Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Participants and RSVP</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.GroupAdd"
                           OnClick="InitializeParticipants">
                    Initialize Participants
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            @if (_participants is null)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            }
            else if (_participants.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No explicit participants yet. Initialize participants to add current members.</MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>@L["Common.Name"]</th>
                            <th>@L["Common.VoiceGroup"]</th>
                            <th>Expectation</th>
                            <th>RSVP</th>
                            <th>Signup</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var participant in _participants)
                        {
                            <tr>
                                <td>@participant.PersonName</td>
                                <td>@(participant.VoiceGroupName ?? "—")</td>
                                <td>@participant.ExpectationStatus</td>
                                <td>
                                    <MudSelect T="RsvpStatus" Value="participant.RsvpStatus" Dense="true" Margin="Margin.Dense"
                                               ValueChanged="@((RsvpStatus value) => SetParticipantRsvp(participant.PersonId, value))">
                                        @foreach (var status in Enum.GetValues<RsvpStatus>())
                                        {
                                            <MudSelectItem T="RsvpStatus" Value="@status">@status</MudSelectItem>
                                        }
                                    </MudSelect>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="@GetSignupStatusColor(participant.SignupStatus)">
                                        @(participant.SignupStatus == SignupStatus.Waitlisted
                                            ? $"Waitlisted #{participant.WaitlistPosition}"
                                            : participant.SignupStatus.ToString())
                                    </MudChip>
                                </td>
                                <td>
                                    @if (participant.SignupStatus == SignupStatus.Waitlisted)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                                   OnClick="@(() => PromoteWaitlisted(participant.PersonId))">
                                            Promote
                                        </MudButton>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudCardContent>
    </MudCard>
}

@* ---- Attendance ---- *@
@if (_attendance is not null && _attendance.Participants.Count > 0)
{
    <MudCard Class="mt-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@string.Format(L["ActivityDetail.AttendanceHeader"], _attendance.Participants.Count(p => p.Status is AttendanceStatus.Present or AttendanceStatus.Late), _attendance.Participants.Count)</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.DoneAll"
                           OnClick="MarkAllPresent"
                           Disabled="_markingAll">
                    @L.H("ActivityDetail.MarkAllPresent")
                </MudButton>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>@L["Common.Name"]</th>
                        <th>@L["Common.VoiceGroup"]</th>
                        <th Style="width:200px;">@L["Common.Status"]</th>
                        <th Style="width:260px;">@L["ActivityDetail.Comment"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _attendance.Participants)
                    {
                        var person = p;
                        <tr>
                            <td>@person.FirstName @person.LastName</td>
                            <td>@(person.VoiceGroupName ?? "—")</td>
                            <td>
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                                   Color="@(person.Status == AttendanceStatus.Present ? Color.Success : Color.Default)"
                                                   Title="@(L["ActivityDetail.StatusPresent"])"
                                                                  OnClick="@(() => SetAttendance(person.PersonId, AttendanceStatus.Present))" />
                                                   <MudIconButton Icon="@Icons.Material.Filled.Schedule" Size="Size.Small"
                                                                  Color="@(person.Status == AttendanceStatus.Late ? Color.Warning : Color.Default)"
                                                                  Title="@(L["ActivityDetail.StatusLate"])"
                                                                  OnClick="@(() => SetAttendance(person.PersonId, AttendanceStatus.Late))" />
                                                   <MudSelect T="AttendanceStatus?" Value="@(IsOtherStatus(person.Status) ? person.Status : null)"
                                                              Placeholder="@(L["ActivityDetail.OtherPlaceholder"])" Dense="true" Margin="Margin.Dense"
                                                              Style="min-width:120px;"
                                                              ValueChanged="@(v => OnOtherStatusChanged(person.PersonId, v))">
                                                       <MudSelectItem T="AttendanceStatus?" Value="@((AttendanceStatus?)AttendanceStatus.NoShow)">@L["ActivityDetail.StatusNoShow"]</MudSelectItem>
                                                       <MudSelectItem T="AttendanceStatus?" Value="@((AttendanceStatus?)AttendanceStatus.Sick)">@L["ActivityDetail.StatusSick"]</MudSelectItem>
                                                       <MudSelectItem T="AttendanceStatus?" Value="@((AttendanceStatus?)AttendanceStatus.ExplainedAbsence)">@L["ActivityDetail.StatusExplained"]</MudSelectItem>
                                    </MudSelect>
                                </MudStack>
                            </td>
                            <td>
                                <MudTextField T="string" Value="@person.Comment" Placeholder="@L["ActivityDetail.CommentPlaceholder"]"
                                              Margin="Margin.Dense" MaxLength="255" Immediate="false"
                                              ValueChanged="@(v => SaveComment(person.PersonId, v))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
    </MudCard>
}

@* ---- Attachments ---- *@
<MudCard Class="mt-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.h6">@L.H("ActivityDetail.Attachments")</MudText>
                @if (_attachments is not null && _attachments.Count > 0)
                {
                    <MudChip T="int" Size="Size.Small" Color="Color.Default">@_attachments.Count</MudChip>
                }
                <MudSpacer />
                <InputFile id="attachmentInput" OnChange="OnFileSelected"
                           style="display:none" accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.mp3,.wav,.m4a,.zip,.rar,.7z,.txt,.csv" />
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Upload"
                           HtmlTag="label" for="attachmentInput"
                           Disabled="_uploading">
                    @L.H("ActivityDetail.UploadAttachment")
                </MudButton>
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (_attachments is null)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
        else if (_attachments.Count == 0)
        {
            <MudText Class="mud-text-secondary">@L["Common.NoResults"]</MudText>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th></th>
                        <th>@L["Common.Name"]</th>
                        <th>@L["Documents.LastUpdated"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _attachments)
                    {
                        var att = a;
                        <tr>
                            <td style="width:36px;">
                                <MudIcon Icon="@GetFileIcon(att.ContentType)" Size="Size.Small" />
                            </td>
                            <td>@att.FileName</td>
                            <td>@att.UploadedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td style="white-space:nowrap;">
                                <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                               Title="@L["Common.Download"]"
                                               OnClick="@(() => Navigation.NavigateTo($"/api/attachments/{att.Id}", forceLoad: true))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               Title="@L["Common.Delete"]"
                                               OnClick="@(() => DeleteAttachment(att))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudCardContent>
</MudCard>

@* ---- Edit Dialog ---- *@
<MudDialog @bind-Visible="_showEdit">
    <TitleContent><MudText Typo="Typo.h6">@L.H("ActivityDetail.EditTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editName" Label="@L["Common.Name"]" Required="true" />
        <MudSelect T="ActivityType" @bind-Value="_editType" Label="@L["Common.Type"]">
            @foreach (var t in Enum.GetValues<ActivityType>().Where(t => t != ActivityType.Semester))
            {
                <MudSelectItem T="ActivityType" Value="@t">@t</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker @bind-Date="_editStartDate" Label="@L["Common.StartDate"]" Required="true" />
        <MudTimePicker @bind-Time="_editStartTime" Label="@L["Common.StartTime"]" />
        <MudDatePicker @bind-Date="_editEndDate" Label="@L["Common.EndDate"]" Required="true" />
        <MudTimePicker @bind-Time="_editEndTime" Label="@L["Common.EndTime"]" />
        <MudTextField @bind-Value="_editLocation" Label="@L["Common.Location"]" />
        <MudTextField @bind-Value="_editDescription" Label="@L["Common.Description"]" Lines="3" />
        <MudSelect T="ActivityStatus" @bind-Value="_editStatus" Label="Status">
            @foreach (var status in Enum.GetValues<ActivityStatus>())
            {
                <MudSelectItem T="ActivityStatus" Value="@status">@status</MudSelectItem>
            }
        </MudSelect>
        <MudCheckBox T="bool" @bind-Value="_editPublicVisible" Label="@L["Common.PublicVisible"]" />
        <MudCheckBox T="bool" @bind-Value="_editRsvpEnabled" Label="RSVP enabled" />
        <MudNumericField T="int?" @bind-Value="_editMaxCapacity" Label="@L["ActivityDetail.MaxCapacity"]" Min="1" />
        <MudCheckBox T="bool" @bind-Value="_editWaitingListEnabled" Label="Waiting list enabled" />
        <MudDatePicker @bind-Date="_editSignupDate" Label="Signup deadline date" Clearable="true" />
        <MudTimePicker @bind-Time="_editSignupTime" Label="Signup deadline time" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEdit = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEdit">@L.H("Common.Save")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid ActivityId { get; set; }

    private ActivityDetailDto? _activity;
    private ActivityAttendanceDto? _attendance;
    private List<ActivityParticipantDto>? _participants;
    private List<ActivityAttachmentDto>? _attachments;
    private bool _notFound;
    private bool _uploading;
    private bool _markingAll;

    // Edit form fields
    private bool _showEdit;
    private string _editName = string.Empty;
    private ActivityType _editType;
    private string? _editDescription;
    private DateTime? _editStartDate;
    private TimeSpan? _editStartTime;
    private DateTime? _editEndDate;
    private TimeSpan? _editEndTime;
    private string? _editLocation;
    private ActivityStatus _editStatus;
    private bool _editPublicVisible;
    private bool _editRsvpEnabled;
    private int? _editMaxCapacity;
    private bool _editWaitingListEnabled = true;
    private DateTime? _editSignupDate;
    private TimeSpan? _editSignupTime;

    private string ActivityBackFallback =>
        _activity?.ParentActivityId is Guid semesterId ? $"/semesters/{semesterId}" : "/activities";

    private string ActivityBackLabel =>
        _activity?.ParentActivityId is Guid
            ? L["ActivityDetail.BackToSemester"]
            : L["ActivityDetail.BackToActivities"];

    protected override async Task OnInitializedAsync()
    {
        await LoadActivity();
    }

    private async Task LoadActivity()
    {
        _activity = await Mediator.Send(new GetActivityDetailQuery(ActivityId));
        if (_activity is null)
        {
            _notFound = true;
            _attendance = null;
            _participants = null;
            _attachments = null;
            return;
        }

        _notFound = false;
        _attendance = await Mediator.Send(new GetActivityAttendanceQuery(ActivityId));
        _participants = await Mediator.Send(new ListActivityParticipantsQuery(ActivityId));
        _attachments = await Mediator.Send(new GetActivityAttachmentsQuery(ActivityId));
    }

    private void StartEdit()
    {
        if (_activity is null) return;

        _editName = _activity.Name;
        _editType = _activity.ActivityType;
        _editDescription = _activity.Description;
        _editStartDate = _activity.StartDateTime.Date;
        _editStartTime = _activity.StartDateTime.TimeOfDay;
        _editEndDate = _activity.EndDateTime.Date;
        _editEndTime = _activity.EndDateTime.TimeOfDay;
        _editLocation = _activity.Location;
        _editStatus = _activity.Status;
        _editPublicVisible = _activity.IsPublicVisible;
        _editRsvpEnabled = _activity.RsvpEnabled;
        _editMaxCapacity = _activity.MaxCapacity;
        _editWaitingListEnabled = _activity.WaitingListEnabled;
        _editSignupDate = _activity.SignupDeadline?.Date;
        _editSignupTime = _activity.SignupDeadline?.TimeOfDay;
        _showEdit = true;
    }

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_editName) || _editStartDate is null || _editEndDate is null)
        {
            Snackbar.Add("Name, start date, and end date are required.", Severity.Warning);
            return;
        }

        if (_editMaxCapacity is <= 0)
        {
            Snackbar.Add("Capacity must be a positive number.", Severity.Warning);
            return;
        }

        var start = _editStartDate.Value + (_editStartTime ?? TimeSpan.Zero);
        var end = _editEndDate.Value + (_editEndTime ?? TimeSpan.Zero);
        if (end < start)
        {
            Snackbar.Add("End date/time must be after start date/time.", Severity.Warning);
            return;
        }

        var signupDeadline = _editSignupDate.HasValue
            ? _editSignupDate.Value + (_editSignupTime ?? TimeSpan.Zero)
            : (DateTime?)null;

        var result = await Mediator.Send(new UpdateActivityCommand(
            ActivityId, _editName, _editDescription, start, end,
            _editLocation, _editPublicVisible, _editMaxCapacity, signupDeadline, _editType,
            _editStatus, _editRsvpEnabled, _editWaitingListEnabled));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["ActivityDetail.Updated"], Severity.Success);
            _showEdit = false;
            await LoadActivity();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task DeleteActivity()
    {
        if (_activity is null) return;

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Activity.DeleteConfirm"], _activity.Name) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Activity.DeleteTitle"], parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new DeleteActivityCommand(ActivityId));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["ActivityDetail.Deleted"], Severity.Success);
            if (_activity.ParentActivityId.HasValue)
                Navigation.NavigateTo($"/semesters/{_activity.ParentActivityId}");
            else
                Navigation.NavigateTo("/activities");
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task SetStatus(ActivityStatus status)
    {
        if (_activity is null) return;

        var result = await Mediator.Send(new UpdateActivityCommand(
            ActivityId, _activity.Name, _activity.Description, _activity.StartDateTime, _activity.EndDateTime,
            _activity.Location, _activity.IsPublicVisible, _activity.MaxCapacity, _activity.SignupDeadline,
            _activity.ActivityType, status, _activity.RsvpEnabled, _activity.WaitingListEnabled));

        if (result.IsSuccess)
        {
            Snackbar.Add($"Activity status set to {status}.", Severity.Success);
            await LoadActivity();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task InitializeParticipants()
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        var result = await Mediator.Send(new InitializeActivityParticipantsCommand(ActivityId, orgId));
        if (result.IsSuccess)
        {
            Snackbar.Add($"Initialized {result.Value} participant(s).", Severity.Success);
            await LoadActivity();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task SetParticipantRsvp(Guid personId, RsvpStatus status)
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        var result = await Mediator.Send(new RsvpCommand(ActivityId, personId, status, orgId));
        if (result.IsSuccess)
        {
            await LoadActivity();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task PromoteWaitlisted(Guid personId)
    {
        var result = await Mediator.Send(new PromoteWaitlistedParticipantCommand(ActivityId, personId));
        if (result.IsSuccess)
        {
            Snackbar.Add("Participant promoted from waiting list.", Severity.Success);
            await LoadActivity();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private static bool IsOtherStatus(AttendanceStatus? status) =>
        status is AttendanceStatus.NoShow or AttendanceStatus.Sick or AttendanceStatus.ExplainedAbsence;

    private static Color GetActivityStatusColor(ActivityStatus status) => status switch
    {
        ActivityStatus.Published => Color.Success,
        ActivityStatus.Cancelled => Color.Error,
        _ => Color.Default,
    };

    private static Color GetSignupStatusColor(SignupStatus status) => status switch
    {
        SignupStatus.Confirmed => Color.Success,
        SignupStatus.Waitlisted => Color.Warning,
        _ => Color.Default,
    };

    private static string GetFileIcon(string contentType) => contentType switch
    {
        "application/pdf" => Icons.Material.Filled.PictureAsPdf,
        var ct when ct.StartsWith("image/") => Icons.Material.Filled.Image,
        var ct when ct.Contains("spreadsheet") || ct.Contains("excel") => Icons.Material.Filled.TableChart,
        _ => Icons.Material.Filled.InsertDriveFile,
    };

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;

        const long maxBytes = 20_971_520L; // 20 MB
        var file = e.File;

        if (file.Size > maxBytes)
        {
            Snackbar.Add(L["ActivityDetail.AttachmentTooLarge"], Severity.Warning);
            return;
        }

        _uploading = true;
        try
        {
            await using var stream = file.OpenReadStream(maxBytes);
            var result = await Mediator.Send(new AttachFileToActivityCommand(
                ActivityId, file.Name, file.ContentType, stream, orgId));

            if (result.IsSuccess)
            {
                Snackbar.Add(L["ActivityDetail.AttachmentUploaded"], Severity.Success);
                _attachments = await Mediator.Send(new GetActivityAttachmentsQuery(ActivityId));
            }
            else
            {
                Snackbar.Add(result.Error!, Severity.Error);
            }
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task DeleteAttachment(ActivityAttachmentDto att)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["ActivityDetail.AttachmentDeleteConfirm"], att.FileName) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["ActivityDetail.AttachmentDeleteTitle"], parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new DeleteActivityAttachmentCommand(att.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["ActivityDetail.AttachmentDeleted"], Severity.Success);
            _attachments = await Mediator.Send(new GetActivityAttachmentsQuery(ActivityId));
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task SetAttendance(Guid personId, AttendanceStatus status)
    {
        var existing = _attendance?.Participants.FirstOrDefault(p => p.PersonId == personId);
        var comment = existing?.Comment;
        await SaveAttendance(personId, status, comment);
    }

    private async Task OnOtherStatusChanged(Guid personId, AttendanceStatus? status)
    {
        if (status is null) return;
        var existing = _attendance?.Participants.FirstOrDefault(p => p.PersonId == personId);
        var comment = existing?.Comment;
        await SaveAttendance(personId, status.Value, comment);
    }

    private async Task SaveComment(Guid personId, string? comment)
    {
        var existing = _attendance?.Participants.FirstOrDefault(p => p.PersonId == personId);
        var status = existing?.Status ?? AttendanceStatus.Present;
        await SaveAttendance(personId, status, comment);
    }

    private async Task SaveAttendance(Guid personId, AttendanceStatus status, string? comment)
    {
        var result = await Mediator.Send(new UpsertAttendanceCommand(ActivityId, personId, status, comment));
        if (result.IsSuccess)
        {
            _attendance = await Mediator.Send(new GetActivityAttendanceQuery(ActivityId));
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task MarkAllPresent()
    {
        if (_attendance is null) return;

        _markingAll = true;
        try
        {
            var unmarked = _attendance.Participants
                .Where(p => p.Status is null or AttendanceStatus.NoShow)
                .ToList();

            foreach (var p in unmarked)
            {
                await Mediator.Send(new UpsertAttendanceCommand(ActivityId, p.PersonId, AttendanceStatus.Present, p.Comment));
            }

            _attendance = await Mediator.Send(new GetActivityAttendanceQuery(ActivityId));
            Snackbar.Add(string.Format(L["ActivityDetail.MarkedAllPresent"], unmarked.Count), Severity.Success);
        }
        finally
        {
            _markingAll = false;
        }
    }
}
