@page "/admin/users"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Organizations.Commands
@using Arelia.Application.Organizations.Queries
@using Arelia.Web.Components.Shared
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Admin.Users.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Admin.Users.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               OnClick="ShowInviteDialog" StartIcon="@Icons.Material.Filled.PersonAdd" Class="mb-4">
        @L.H("Admin.Users.InviteUser")
    </MudButton>

    @if (_users is not null)
    {
        <ConfigurableTable TItem="OrganizationUserDto" Items="_users" Columns="_columns">
            <CellTemplate>
                @switch (context.ColumnKey)
                {
                    case "Status":
                        <MudChip T="string" Color="@((bool)(context.Value ?? false) ? Color.Success : Color.Default)" Size="Size.Small">
                            @((bool)(context.Value ?? false) ? L["Common.Active"] : L["Common.FormerMember"])
                        </MudChip>
                        break;
                    default:
                        @(context.Value?.ToString() ?? "—")
                        break;
                }
            </CellTemplate>
            <RowActions>
                @if (context.IsActive)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.PersonOff"
                                   Color="Color.Warning" Size="Size.Small"
                                   OnClick="@(() => DeactivateUser(context))" />
                }
            </RowActions>
        </ConfigurableTable>
    }
}

<MudDialog @bind-Visible="_showInvite">
    <TitleContent>
        <MudText Typo="Typo.h6">@L.H("Admin.Users.InviteTitle")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteEmail" Label="@L["Common.Email"]" Required="true" InputType="InputType.Email" />
        <MudTextField @bind-Value="_inviteFirstName" Label="@L["Common.FirstName"]" />
        <MudTextField @bind-Value="_inviteLastName" Label="@L["Common.LastName"]" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showInvite = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="InviteUser">@L.H("Common.Invite")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<OrganizationUserDto>? _users;
    private bool _showInvite;
    private string _inviteEmail = string.Empty;
    private string? _inviteFirstName;
    private string? _inviteLastName;

    private List<ColumnDefinition<OrganizationUserDto>>? _columns;

    protected override async Task OnInitializedAsync()
    {
        _columns =
        [
            new("Name", L["Common.Name"], x => x.PersonName),
            new("Email", L["Common.Email"], x => x.Email),
            new("Status", L["Common.Status"], x => x.IsActive),
        ];
        RegisterTenantChangeHandler();
        await LoadUsers();
    }

    protected override Task OnTenantChangedAsync() => LoadUsers();

    private async Task LoadUsers()
    {
        if (TenantService.CurrentOrganizationId is Guid orgId)
        {
            _users = await Mediator.Send(new GetOrganizationUsersQuery(orgId));
        }
    }

    private void ShowInviteDialog()
    {
        _inviteEmail = string.Empty;
        _inviteFirstName = null;
        _inviteLastName = null;
        _showInvite = true;
    }

    private async Task InviteUser()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail) || TenantService.CurrentOrganizationId is not Guid orgId)
            return;

        var result = await Mediator.Send(new InviteUserCommand(_inviteEmail, orgId, _inviteFirstName, _inviteLastName));
        if (result.IsSuccess)
        {
            Snackbar.Add(string.Format(L["Admin.Users.InvitationSent"], _inviteEmail), Severity.Success);
            _showInvite = false;
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task DeactivateUser(OrganizationUserDto user)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Admin.Users.DeactivateConfirm"], user.PersonName ?? user.Email ?? L["Common.FormerMember"]) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Admin.Users.DeactivateTitle"], parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new DeactivateOrganizationUserCommand(user.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Admin.Users.Deactivated"], Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }
}
