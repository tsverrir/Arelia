@page "/admin/users"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Organizations.Commands
@using Arelia.Application.Organizations.Queries
@using Arelia.Web.Components.Shared
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Admin.Users.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Admin.Users.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
}
else
{
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               OnClick="ShowInviteDialog" StartIcon="@Icons.Material.Filled.PersonAdd" Class="mb-4">
        @L.H("Admin.Users.InviteUser")
    </MudButton>

    @if (_users is not null)
    {
        <MudTable Items="_users" Hover="true" Striped="true" Dense="true">
            <HeaderContent>
                <MudTh>@L["Common.Name"]</MudTh>
                <MudTh>@L["Common.Email"]</MudTh>
                <MudTh>@L["Common.Roles"]</MudTh>
                <MudTh>@L["Common.Status"]</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Common.Name"]">@(context.PersonName ?? "—")</MudTd>
                <MudTd DataLabel="@L["Common.Email"]">@(context.Email ?? "—")</MudTd>
                <MudTd DataLabel="@L["Common.Roles"]">
                    @if (context.ActiveRoles.Any())
                    {
                        @string.Join(", ", context.ActiveRoles)
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Common.NoActiveRoles"]</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="@L["Common.Status"]">
                    @if (context.IsPending)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">@L["Common.Pending"]</MudChip>
                    }
                    else if (context.ActiveRoles.Any())
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["Common.Active"]</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["Common.Suspended"]</MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudStack Row="true">
                        @if (context.IsPending)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ForwardToInbox"
                                           Color="Color.Info" Size="Size.Small"
                                           Title="@L["Admin.Users.ResendInvite"]"
                                           OnClick="@(() => ResendInvite(context))" />
                        }
                        @if (context.ActiveRoles.Any())
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.PersonOff"
                                           Color="Color.Warning" Size="Size.Small"
                                           Title="@L["Admin.Users.SuspendTitle"]"
                                           OnClick="@(() => SuspendUser(context))" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                       Color="Color.Error" Size="Size.Small"
                                       Title="@L["Admin.Users.RemoveTitle"]"
                                       OnClick="@(() => RemoveUser(context))" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

<MudDialog @bind-Visible="_showInvite">
    <TitleContent>
        <MudText Typo="Typo.h6">@L.H("Admin.Users.InviteTitle")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteEmail" Label="@L["Common.Email"]" Required="true" InputType="InputType.Email" Class="mb-2" />
        <MudTextField @bind-Value="_inviteFirstName" Label="@L["Common.FirstName"]" Class="mb-2" />
        <MudTextField @bind-Value="_inviteLastName" Label="@L["Common.LastName"]" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showInvite = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="InviteUser">@L.H("Common.Invite")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<OrganizationUserDto>? _users;
    private bool _showInvite;
    private string _inviteEmail = string.Empty;
    private string? _inviteFirstName;
    private string? _inviteLastName;

    protected override async Task OnInitializedAsync()
    {
        RegisterTenantChangeHandler();
        await LoadUsers();
    }

    protected override Task OnTenantChangedAsync() => LoadUsers();

    private async Task LoadUsers()
    {
        if (TenantService.CurrentOrganizationId is Guid orgId)
            _users = await Mediator.Send(new GetOrganizationUsersQuery(orgId));
    }

    private void ShowInviteDialog()
    {
        _inviteEmail = string.Empty;
        _inviteFirstName = null;
        _inviteLastName = null;
        _showInvite = true;
    }

    private async Task InviteUser()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail))
        {
            Snackbar.Add(L["Common.EmailRequired"], Severity.Warning);
            return;
        }

        if (TenantService.CurrentOrganizationId is not Guid orgId)
            return;

        var result = await Mediator.Send(new InviteUserCommand(
            orgId, _inviteEmail, _inviteFirstName, _inviteLastName,
            null, null, "Admin", Navigation.BaseUri.TrimEnd('/')));

        if (result.IsSuccess)
        {
            Snackbar.Add(string.Format(L["Admin.Users.InvitationSent"], _inviteEmail), Severity.Success);
            _showInvite = false;
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task SuspendUser(OrganizationUserDto user)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Admin.Users.SuspendConfirm"], user.PersonName ?? user.Email ?? "—") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Admin.Users.SuspendTitle"], parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new SuspendOrganizationUserCommand(user.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Admin.Users.Suspended"], Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task RemoveUser(OrganizationUserDto user)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Admin.Users.RemoveConfirm"], user.PersonName ?? user.Email ?? "—") }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Admin.Users.RemoveTitle"], parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new RemoveOrganizationUserCommand(user.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Admin.Users.Removed"], Severity.Success);
            await LoadUsers();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task ResendInvite(OrganizationUserDto user)
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId)
            return;

        var result = await Mediator.Send(new ResendInvitationCommand(
            user.UserId, orgId, "Admin", Navigation.BaseUri.TrimEnd('/')));

        if (result.IsSuccess)
            Snackbar.Add(L["Admin.Users.InviteResent"], Severity.Success);
        else
            Snackbar.Add(result.Error!, Severity.Error);
    }
}
