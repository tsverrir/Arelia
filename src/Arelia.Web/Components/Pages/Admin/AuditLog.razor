@page "/admin/audit"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.AuditLog.Queries
@using Arelia.Web.Components.Shared
@using MediatR
@inject IMediator Mediator
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Audit Log</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Audit Log</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">Please select an organization first.</MudAlert>
    return;
}

@if (_entries is not null)
{
    <ConfigurableTable TItem="AuditLogEntryDto" Items="_entries" Columns="_columns">
        <CellTemplate>
            @switch (context.ColumnKey)
            {
                case "Timestamp":
                    @(context.Value is DateTime dt ? dt.ToString("yyyy-MM-dd HH:mm:ss") : "—")
                    break;
                case "Action":
                    <MudChip T="string" Size="Size.Small">@context.Value</MudChip>
                    break;
                case "Entity":
                    @($"{context.Item.EntityType ?? "—"} {(context.Item.EntityId is not null ? $"({context.Item.EntityId[..Math.Min(8, context.Item.EntityId.Length)]})" : "")}")
                    break;
                case "Details":
                    <span style="max-width:300px; overflow:hidden; text-overflow:ellipsis; display:inline-block;">
                        @(context.Value?.ToString() ?? "—")
                    </span>
                    break;
                default:
                    @(context.Value?.ToString() ?? "—")
                    break;
            }
        </CellTemplate>
    </ConfigurableTable>
}

@code {
    private List<AuditLogEntryDto>? _entries;

    private readonly List<ColumnDefinition<AuditLogEntryDto>> _columns =
    [
        new("Timestamp", "Timestamp", x => x.Timestamp),
        new("Action", "Action", x => x.Action),
        new("Entity", "Entity", x => x.EntityType),
        new("User", "User", x => x.UserId),
        new("Details", "Details", x => x.Details),
    ];

    protected override async Task OnInitializedAsync()
    {
        RegisterTenantChangeHandler();
        await LoadEntries();
    }

    protected override Task OnTenantChangedAsync() => LoadEntries();

    private async Task LoadEntries()
    {
        if (TenantService.CurrentOrganizationId is Guid orgId)
            _entries = await Mediator.Send(new GetAuditLogQuery(orgId));
    }
}
