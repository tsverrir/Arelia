@page "/admin/backups"
@using Arelia.Infrastructure.Services
@using Microsoft.Data.Sqlite
@inject BackupService BackupService
@inject IConfiguration Configuration
@inject ISnackbar Snackbar
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Admin.Backups.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Admin.Backups.Title")</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateBackup"
           StartIcon="@Icons.Material.Filled.Backup" Class="mb-4"
           Disabled="@_isCreating">
    @(_isCreating ? L["Admin.Backups.Creating"] : L["Admin.Backups.Create"])
</MudButton>

@if (_backups is not null && _backups.Count > 0)
{
    <MudTable Items="_backups" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>@L["Common.File"]</MudTh>
            <MudTh>@L["Common.Size"]</MudTh>
            <MudTh>@L["Common.Created"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.FileName</MudTd>
            <MudTd>@FormatSize(context.SizeBytes)</MudTd>
            <MudTd>@context.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss UTC")</MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudAlert Severity="Severity.Info">@L["Admin.Backups.NoBackups"]</MudAlert>
}

@code {
    private List<BackupInfo>? _backups;
    private bool _isCreating;

    private string BackupDir => Configuration["Backup:Directory"] ?? "backups";
    private string DbPath
    {
        get
        {
            var connectionString = Configuration.GetConnectionString("DefaultConnection") ?? "DataSource=arelia.db";
            var builder = new SqliteConnectionStringBuilder(connectionString);
            return builder.DataSource;
        }
    }

    protected override void OnInitialized()
    {
        _backups = BackupService.GetBackups(BackupDir);
    }

    private async Task CreateBackup()
    {
        _isCreating = true;
        try
        {
            var path = await BackupService.CreateBackupAsync(DbPath, BackupDir);
            Snackbar.Add(string.Format(L["Admin.Backups.Created"], Path.GetFileName(path)), Severity.Success);
            _backups = BackupService.GetBackups(BackupDir);
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(L["Admin.Backups.Failed"], ex.Message), Severity.Error);
        }
        finally
        {
            _isCreating = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{bytes / 1024.0:N1} KB";
        return $"{bytes / (1024.0 * 1024.0):N1} MB";
    }
}
