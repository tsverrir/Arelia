@page "/finances"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Activities.Queries
@using Arelia.Application.Finance.Commands
@using Arelia.Application.Finance.Queries
@using Arelia.Application.People.Queries
@using Arelia.Application.Reports.Queries
@using Arelia.Application.Finance.ExpenseCategories.Queries
@using Arelia.Domain.Enums
@using Arelia.Web.Components.Shared
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["Finance.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("Finance.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
    return;
}

<MudTabs Elevation="0" Rounded="true" PanelClass="pa-6">
    <MudTabPanel Text="@L["Finance.Summary"]" Icon="@Icons.Material.Filled.Dashboard">
        @if (_summary is not null)
        {
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">@L["Finance.TotalCharged"]</MudText>
                        <MudText Typo="Typo.h5">@_summary.TotalChargesDue.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">@L["Finance.TotalCollected"]</MudText>
                        <MudText Typo="Typo.h5" Color="Color.Success">@_summary.TotalChargesPaid.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">@L["Finance.TotalExpenses"]</MudText>
                        <MudText Typo="Typo.h5" Color="Color.Error">@_summary.TotalExpenses.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">@L["Finance.NetBalance"]</MudText>
                        <MudText Typo="Typo.h5" Color="@(_summary.NetBalance >= 0 ? Color.Success : Color.Error)">@_summary.NetBalance.ToString("N2")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Finance.ChargeStatus"]</MudText>
                        <MudStack Spacing="1">
                            <MudText>@string.Format(L["Finance.OpenCharges"], _summary.OpenChargeCount)</MudText>
                            <MudText Color="Color.Warning">@string.Format(L["Finance.OverdueCharges"], _summary.OverdueChargeCount)</MudText>
                        </MudStack>
                    </MudPaper>
                </MudItem>
                @if (_summary.ExpensesByCategory.Count > 0)
                {
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Finance.ExpensesByCategory"]</MudText>
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    @foreach (var cat in _summary.ExpensesByCategory)
                                    {
                                        <tr>
                                            <td>@cat.Category</td>
                                            <td style="text-align:right;">@cat.Amount.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    </MudItem>
                }
                @if (_summary.CreditBalances.Count > 0)
                {
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="pa-4" Elevation="1">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Credit balances</MudText>
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    @foreach (var credit in _summary.CreditBalances)
                                    {
                                        <tr>
                                            <td>@credit.PersonName</td>
                                            <td style="text-align:right;">@credit.BalanceAmount.ToString("N2") @credit.CurrencyCode</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
    </MudTabPanel>

    <MudTabPanel Text="@L["Finance.Charges"]">
        <MudStack Row="true" Class="mb-4" AlignItems="AlignItems.Center" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="OpenRecordPayment" StartIcon="@Icons.Material.Filled.Payment">
                @L.H("Finance.RecordPayment")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                       OnClick="OpenGenerateFees" StartIcon="@Icons.Material.Filled.AutoMode">
                @L.H("Finance.GenerateFees")
            </MudButton>
            <MudSpacer />
            <MudCheckBox T="bool" Value="_showChargeHistory" Label="@L["Finance.ShowHistory"]"
                         ValueChanged="@(async (bool v) => { _showChargeHistory = v; await LoadFinances(); })" />
        </MudStack>
        @if (_charges is not null)
        {
            <ConfigurableTable TItem="ChargeListDto" Items="_charges" Columns="_chargeColumns">
                <CellTemplate>
                    @switch (context.ColumnKey)
                    {
                        case "Status":
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor((Arelia.Domain.Enums.ChargeStatus)context.Value!)">
                                @context.Value
                            </MudChip>
                            break;
                        case "Due":
                            @($"{context.Item.TotalDue:N2} {context.Item.CurrencyCode}")
                            break;
                        case "Paid":
                            @($"{context.Item.TotalPaid:N2} {context.Item.CurrencyCode}")
                            break;
                        case "DueDate":
                            @(context.Value is DateTime dtDue ? dtDue.ToString("yyyy-MM-dd") : "—")
                            break;
                        default:
                            @(context.Value?.ToString() ?? "—")
                            break;
                    }
                </CellTemplate>
                <RowActions>
                    @if (context.IsActive)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Payment" Size="Size.Small" Color="Color.Success"
                                       OnClick="@(() => OpenRecordPaymentForCharge(context))" Title="@L["Finance.RecordPayment"]" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditCharge(context))" Title="@L["Common.Edit"]" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteCharge(context))" Title="@L["Common.Delete"]" />
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                            @(context.ReplacedById.HasValue ? L["Finance.Revised"] : L["Finance.Deleted"])
                        </MudChip>
                    }
                </RowActions>
            </ConfigurableTable>
        }
    </MudTabPanel>

    <MudTabPanel Text="@L["Finance.Expenses"]">
        <MudStack Row="true" Class="mb-4" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="@(() => OpenCreateExpense())" StartIcon="@Icons.Material.Filled.Add">
                @L.H("Finance.RecordExpense")
            </MudButton>
            <MudSpacer />
            <MudCheckBox T="bool" Value="_showExpenseHistory" Label="@L["Finance.ShowHistory"]"
                         ValueChanged="@(async (bool v) => { _showExpenseHistory = v; await LoadFinances(); })" />
        </MudStack>
        @if (_expenses is not null)
        {
            <ConfigurableTable TItem="ExpenseListDto" Items="_expenses" Columns="_expenseColumns">
                <CellTemplate>
                    @switch (context.ColumnKey)
                    {
                        case "Date":
                            @(context.Value is DateTime dtExp ? dtExp.ToString("yyyy-MM-dd") : "—")
                            break;
                        case "Amount":
                            @($"{context.Item.Amount:N2} {context.Item.CurrencyCode}")
                            break;
                        default:
                            @(context.Value?.ToString() ?? "—")
                            break;
                    }
                </CellTemplate>
                <RowActions>
                    @if (context.IsActive)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditExpense(context))" Title="@L["Common.Edit"]" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteExpense(context))" Title="@L["Common.Delete"]" />
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                            @(context.ReplacedById.HasValue ? L["Finance.Revised"] : L["Finance.Deleted"])
                        </MudChip>
                    }
                </RowActions>
            </ConfigurableTable>
        }
    </MudTabPanel>
</MudTabs>

@* ---- Create / Edit Expense Dialog ---- *@
<MudDialog @bind-Visible="_showExpense">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editExpenseId is null ? L.H("Finance.RecordExpenseTitle") : L.H("Finance.EditExpenseTitle"))</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_expDesc" Label="@L["Common.Description"]" Required="true" />
        <MudNumericField T="decimal" @bind-Value="_expAmount" Label="@L["Common.Amount"]" Required="true" />
        <MudDatePicker @bind-Date="_expDate" Label="@L["Common.Date"]" Required="true" />
        <MudSelect T="Guid?" @bind-Value="_expCategoryId" Label="@L["Common.Category"]" Required="true">
            @if (_expenseCategories is not null)
            {
                @foreach (var c in _expenseCategories)
                {
                    <MudSelectItem T="Guid?" Value="@c.Id">@c.Name</MudSelectItem>
                }
            }
        </MudSelect>
        <MudTextField @bind-Value="_expReceivedBy" Label="@L["Finance.ReceivedBy"]" />
        <MudTextField @bind-Value="_expNotes" Label="@L["Common.Notes"]" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showExpense = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveExpense">@L.H("Common.Save")</MudButton>
    </DialogActions>
</MudDialog>

@* ---- Edit Charge Dialog ---- *@
<MudDialog @bind-Visible="_showEditCharge">
    <TitleContent><MudText Typo="Typo.h6">@L.H("Finance.EditChargeTitle")</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editChargeDesc" Label="@L["Common.Description"]" Required="true" />
        <MudDatePicker @bind-Date="_editChargeDueDate" Label="@L["Finance.DueDate"]" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEditCharge = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCharge">@L.H("Common.Save")</MudButton>
    </DialogActions>
</MudDialog>

@* ---- Record Payment Dialog ---- *@
<MudDialog @bind-Visible="_showPayment">
    <TitleContent><MudText Typo="Typo.h6">@L.H("Finance.RecordPaymentTitle")</MudText></TitleContent>
    <DialogContent>
        @if (_payChargeId is null)
        {
            <MudSelect T="Guid?" @bind-Value="_payChargeId" Label="@L["Finance.LinkedCharge"]" Clearable="true">
                @if (_charges is not null)
                {
                    @foreach (var c in _charges.Where(c => c.IsActive && c.Status != ChargeStatus.Paid))
                    {
                        <MudSelectItem T="Guid?" Value="@c.Id">@c.PersonName — @c.Description (@((c.TotalDue - c.TotalPaid).ToString("N2")))</MudSelectItem>
                    }
                }
            </MudSelect>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">@_payChargeLabel</MudAlert>
        }
        <MudNumericField T="decimal" @bind-Value="_payAmount" Label="@L["Common.Amount"]" Required="true" Min="0.01m" />
        <MudDatePicker @bind-Date="_payDate" Label="@L["Common.Date"]" Required="true" />
        <MudTextField @bind-Value="_payMethod" Label="@L["Finance.PaymentMethod"]" />
        <MudTextField @bind-Value="_payReference" Label="@L["Finance.Reference"]" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPayment = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePayment">@L.H("Common.Save")</MudButton>
    </DialogActions>
</MudDialog>

@* ---- Generate Membership Fees Dialog ---- *@
<MudDialog @bind-Visible="_showGenerateFees">
    <TitleContent><MudText Typo="Typo.h6">@L.H("Finance.GenerateFeesTitle")</MudText></TitleContent>
    <DialogContent>
        <MudSelect T="Guid?" @bind-Value="_feeSemesterId" Label="@L["Finance.Semester"]" Required="true">
            @if (_semesters is not null)
            {
                @foreach (var s in _semesters)
                {
                    <MudSelectItem T="Guid?" Value="@s.Id">@s.Name (@s.WorkYear)</MudSelectItem>
                }
            }
        </MudSelect>
        <MudNumericField T="decimal" @bind-Value="_feeBaseAmount" Label="@L["Finance.BaseFee"]" Required="true" Min="0" />
        <MudNumericField T="decimal?" @bind-Value="_feeTopUpAmount" Label="@L["Finance.TopUpOptional"]" />
        <MudDatePicker @bind-Date="_feeDueDate" Label="@L["Finance.DueDate"]" Required="true" />
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
            @L["Finance.GenerateFeesInfo"]
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showGenerateFees = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ExecuteGenerateFees">@L.H("Finance.Generate")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ChargeListDto>? _charges;
    private List<ExpenseListDto>? _expenses;
    private List<ExpenseCategoryDto>? _expenseCategories;
    private FinanceSummaryDto? _summary;
    private List<ActivityListDto>? _semesters;
    private bool _showExpenseHistory;
    private bool _showChargeHistory;

    // Expense dialog state
    private bool _showExpense;
    private Guid? _editExpenseId;
    private string _expDesc = string.Empty;
    private decimal _expAmount;
    private DateTime? _expDate = DateTime.Today;
    private Guid? _expCategoryId;
    private string? _expReceivedBy;
    private string? _expNotes;

    // Charge edit dialog state
    private bool _showEditCharge;
    private Guid? _editChargeId;
    private string _editChargeDesc = string.Empty;
    private DateTime? _editChargeDueDate;

    // Payment dialog state
    private bool _showPayment;
    private Guid? _payChargeId;
    private Guid? _payPayerPersonId;
    private string? _payChargeLabel;
    private decimal _payAmount;
    private DateTime? _payDate = DateTime.Today;
    private string? _payMethod;
    private string? _payReference;

    // Generate fees dialog state
    private bool _showGenerateFees;
    private Guid? _feeSemesterId;
    private decimal _feeBaseAmount;
    private decimal? _feeTopUpAmount;
    private DateTime? _feeDueDate;

    private List<ColumnDefinition<ChargeListDto>>? _chargeColumns;
    private List<ColumnDefinition<ExpenseListDto>>? _expenseColumns;

    protected override async Task OnInitializedAsync()
    {
        _chargeColumns =
        [
            new("Member", L["Finance.Member"], x => x.PersonName),
            new("Description", L["Common.Description"], x => x.Description),
            new("DueDate", L["Finance.DueDate"], x => x.DueDate),
            new("Due", L["Finance.Due"], x => x.TotalDue),
            new("Paid", L["Finance.Paid"], x => x.TotalPaid),
            new("Status", L["Common.Status"], x => x.Status),
        ];
        _expenseColumns =
        [
            new("Date", L["Common.Date"], x => x.ExpenseDate),
            new("Description", L["Common.Description"], x => x.Description),
            new("Category", L["Common.Category"], x => x.CategoryName),
            new("Amount", L["Common.Amount"], x => x.Amount),
            new("ReceivedBy", L["Finance.ReceivedBy"], x => x.ReceivedBy),
        ];
        RegisterTenantChangeHandler();
        await LoadFinances();
    }

    protected override Task OnTenantChangedAsync() => LoadFinances();

    private async Task LoadFinances()
    {
        if (TenantService.CurrentOrganizationId is Guid orgId)
        {
            _charges = await Mediator.Send(new GetChargesQuery(orgId, IncludeHistory: _showChargeHistory));
            _expenses = await Mediator.Send(new GetExpensesQuery(orgId, IncludeHistory: _showExpenseHistory));
            _expenseCategories = await Mediator.Send(new GetExpenseCategoriesQuery(orgId));
            _summary = await Mediator.Send(new GetFinanceSummaryQuery(orgId, DateTime.Now.Year));
            _semesters ??= await Mediator.Send(new GetActivitiesQuery(orgId, TypeFilter: ActivityType.Semester));
        }
    }

    // ---- Expense CRUD ----

    private void OpenCreateExpense()
    {
        _editExpenseId = null;
        _expDesc = string.Empty;
        _expAmount = 0;
        _expDate = DateTime.Today;
        _expCategoryId = null;
        _expReceivedBy = null;
        _expNotes = null;
        _showExpense = true;
    }

    private void OpenEditExpense(ExpenseListDto expense)
    {
        _editExpenseId = expense.Id;
        _expDesc = expense.Description;
        _expAmount = expense.Amount;
        _expDate = expense.ExpenseDate;
        _expCategoryId = expense.CategoryId;
        _expReceivedBy = expense.ReceivedBy;
        _expNotes = expense.Notes;
        _showExpense = true;
    }

    private async Task SaveExpense()
    {
        if (string.IsNullOrWhiteSpace(_expDesc) || _expDate is null || _expCategoryId is null
            || TenantService.CurrentOrganizationId is not Guid orgId)
        {
            Snackbar.Add("Description, date, and category are required.", Severity.Warning);
            return;
        }

        if (_expAmount <= 0)
        {
            Snackbar.Add("Expense amount must be greater than zero.", Severity.Warning);
            return;
        }

        if (_editExpenseId is Guid existingId)
        {
            var result = await Mediator.Send(new UpdateExpenseCommand(
                existingId, _expDesc, _expAmount, _expDate.Value,
                _expCategoryId.Value, _expReceivedBy, _expNotes));

            if (result.IsSuccess)
            {
                Snackbar.Add(L["Finance.ExpenseUpdated"], Severity.Success);
                _showExpense = false;
                await LoadFinances();
            }
            else
            {
                Snackbar.Add(result.Error!, Severity.Error);
            }
        }
        else
        {
            var categoryName = _expenseCategories?.FirstOrDefault(c => c.Id == _expCategoryId)?.Name ?? string.Empty;
            var result = await Mediator.Send(new RecordExpenseCommand(
                _expDesc, _expAmount, _expDate.Value, categoryName, _expReceivedBy, _expNotes, orgId));

            if (result.IsSuccess)
            {
                Snackbar.Add(L["Finance.ExpenseRecorded"], Severity.Success);
                _showExpense = false;
                await LoadFinances();
            }
            else
            {
                Snackbar.Add(result.Error!, Severity.Error);
            }
        }
    }

    private async Task DeleteExpense(ExpenseListDto expense)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Finance.DeleteExpenseConfirm"], expense.Description) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Finance.DeleteExpenseTitle"], parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new SoftDeleteExpenseCommand(expense.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Finance.ExpenseDeleted"], Severity.Success);
            await LoadFinances();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    // ---- Charge CRUD ----

    private void OpenEditCharge(ChargeListDto charge)
    {
        _editChargeId = charge.Id;
        _editChargeDesc = charge.Description;
        _editChargeDueDate = charge.DueDate;
        _showEditCharge = true;
    }

    private async Task SaveCharge()
    {
        if (string.IsNullOrWhiteSpace(_editChargeDesc) || _editChargeDueDate is null || _editChargeId is null)
        {
            Snackbar.Add("Description and due date are required.", Severity.Warning);
            return;
        }

        var result = await Mediator.Send(new UpdateChargeCommand(
            _editChargeId.Value, _editChargeDesc, _editChargeDueDate.Value));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["Finance.ChargeUpdated"], Severity.Success);
            _showEditCharge = false;
            await LoadFinances();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task DeleteCharge(ChargeListDto charge)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["Finance.DeleteChargeConfirm"], charge.Description) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["Finance.DeleteChargeTitle"], parameters);
        var dialogResult = await dialog.Result;

        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new SoftDeleteChargeCommand(charge.Id));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["Finance.ChargeDeleted"], Severity.Success);
            await LoadFinances();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private static Color GetStatusColor(Arelia.Domain.Enums.ChargeStatus status) => status switch
    {
        Arelia.Domain.Enums.ChargeStatus.Paid => Color.Success,
        Arelia.Domain.Enums.ChargeStatus.PartiallyPaid => Color.Warning,
        Arelia.Domain.Enums.ChargeStatus.Overpaid => Color.Info,
        _ => Color.Default,
    };

    // ---- Payment recording ----

    private void OpenRecordPayment()
    {
        _payChargeId = null;
        _payPayerPersonId = null;
        _payChargeLabel = null;
        _payAmount = 0;
        _payDate = DateTime.Today;
        _payMethod = null;
        _payReference = null;
        _showPayment = true;
    }

    private void OpenRecordPaymentForCharge(ChargeListDto charge)
    {
        _payChargeId = charge.Id;
        _payPayerPersonId = charge.PersonId;
        _payChargeLabel = $"{charge.PersonName} — {charge.Description}";
        _payAmount = charge.TotalDue - charge.TotalPaid;
        _payDate = DateTime.Today;
        _payMethod = null;
        _payReference = null;
        _showPayment = true;
    }

    private async Task SavePayment()
    {
        if (_payAmount <= 0 || _payDate is null || TenantService.CurrentOrganizationId is not Guid orgId)
        {
            Snackbar.Add("Payment amount and date are required.", Severity.Warning);
            return;
        }

        // Determine payer from charge if linked
        string payerDesc = "—";
        Guid? payerPersonId = _payPayerPersonId;
        if (_payChargeId.HasValue && _charges is not null)
        {
            var linkedCharge = _charges.FirstOrDefault(c => c.Id == _payChargeId);
            if (linkedCharge is not null)
                payerDesc = linkedCharge.PersonName;
        }

        var result = await Mediator.Send(new RecordPaymentCommand(
            _payChargeId, payerPersonId, payerDesc, _payAmount, _payDate.Value,
            _payMethod, _payReference, "DKK", null, null, orgId));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["Finance.PaymentRecorded"], Severity.Success);
            _showPayment = false;
            await LoadFinances();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    // ---- Fee generation ----

    private void OpenGenerateFees()
    {
        _feeSemesterId = null;
        _feeBaseAmount = 0;
        _feeTopUpAmount = null;
        _feeDueDate = DateTime.Today.AddMonths(1);
        _showGenerateFees = true;
    }

    private async Task ExecuteGenerateFees()
    {
        if (_feeSemesterId is null || _feeBaseAmount <= 0 || _feeDueDate is null
            || TenantService.CurrentOrganizationId is not Guid orgId)
        {
            Snackbar.Add("Select a semester, enter a base fee greater than zero, and choose a due date.", Severity.Warning);
            return;
        }

        if (_feeTopUpAmount is <= 0)
        {
            Snackbar.Add("Optional top-up must be greater than zero when provided.", Severity.Warning);
            return;
        }

        var result = await Mediator.Send(new GenerateMembershipFeesCommand(
            _feeSemesterId.Value, _feeBaseAmount, _feeTopUpAmount, _feeDueDate.Value, orgId));

        if (result.IsSuccess)
        {
            Snackbar.Add(string.Format(L["Finance.FeesGenerated"], result.Value), Severity.Success);
            _showGenerateFees = false;
            await LoadFinances();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }
}
