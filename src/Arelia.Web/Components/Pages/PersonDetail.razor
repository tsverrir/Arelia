@page "/people/{PersonId:guid}"
@using Arelia.Application.Interfaces
@using Arelia.Application.People.Commands
@using Arelia.Application.People.Queries
@using Arelia.Application.Roles.Commands
@using Arelia.Application.Roles.Queries
@using Arelia.Domain.Enums
@using MediatR
@inject IMediator Mediator
@inject ITenantContext TenantContext
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@(_person is null ? L["People.Title"] : $"{_person.FirstName} {_person.LastName}")</PageTitle>

@if (_person is null)
{
    <MudProgressCircular Indeterminate="true" />
    return;
}

<MudText Typo="Typo.h5" GutterBottom="true">@_person.FirstName @_person.LastName</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardContent>
                <MudTextField @bind-Value="_editFirstName" Label="@L["Common.FirstName"]" />
                <MudTextField @bind-Value="_editLastName" Label="@L["Common.LastName"]" />
                <MudTextField @bind-Value="_editEmail" Label="@L["Common.Email"]" />
                <MudTextField @bind-Value="_editPhone" Label="@L["Common.Phone"]" />
                <MudSelect T="VoiceGroup?" @bind-Value="_editVoiceGroup" Label="@L["Common.VoiceGroup"]" Clearable="true">
                    @foreach (var vg in Enum.GetValues<VoiceGroup>())
                    {
                        <MudSelectItem T="VoiceGroup?" Value="@vg">@VoiceGroupLabel(vg)</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_editNotes" Label="@L["Common.Notes"]" Lines="3" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveChanges">@L.H("Common.Save")</MudButton>
                @if (_person.IsActive)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="DeactivatePerson">@L.H("Common.Deactivate")</MudButton>
                }
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h6">@L.H("PersonDetail.RoleAssignments")</MudText>
            </MudCardHeader>
            <MudCardContent>
                @if (_person.HasLinkedUser)
                {
                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Class="mb-2">@L["PersonDetail.HasLinkedUser"]</MudChip>
                }

                <MudTable Items="_person.RoleAssignments" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>@L["Common.Role"]</MudTh>
                        <MudTh>@L["Common.From"]</MudTh>
                        <MudTh>@L["Common.To"]</MudTh>
                        <MudTh>@L["Common.Status"]</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RoleName</MudTd>
                        <MudTd>@context.FromDate.ToString("yyyy-MM-dd")</MudTd>
                        <MudTd>@(context.ToDate?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.IsCurrentlyActive ? Color.Success : Color.Default)">
                                @(context.IsCurrentlyActive ? L["Common.Active"] : L["Common.Ended"])
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            @if (context.IsCurrentlyActive)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.EventBusy" Size="Size.Small"
                                                               OnClick="@(() => EndRoleAssignment(context.Id))"
                                                               Title="@(L["PersonDetail.EndAssignmentTitle"])" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveRoleAssignment(context.Id))"
                                                          Title="@(L["PersonDetail.RemoveAssignmentTitle"])" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudDivider Class="my-3" />

                <MudText Typo="Typo.subtitle1" GutterBottom="true">@L.H("PersonDetail.AssignRole")</MudText>
                <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2">
                    <MudSelect T="Guid?" @bind-Value="_selectedRoleId" Label="@L["Common.Role"]" Clearable="true">
                        @if (_roles is not null)
                        {
                            @foreach (var role in _roles.Where(r => r.IsActive))
                            {
                                <MudSelectItem T="Guid?" Value="@role.Id">@role.Name</MudSelectItem>
                            }
                        }
                    </MudSelect>
                    <MudDatePicker @bind-Date="_assignFromDate" Label="@L["Common.From"]" />
                    <MudDatePicker @bind-Date="_assignToDate" Label="@L["Common.EndDateOptional"]" Clearable="true" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AssignRole"
                               Disabled="@(_selectedRoleId is null)">
                        @L.H("Common.Assign")
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public Guid PersonId { get; set; }

    private PersonDetailDto? _person;
    private List<RoleDto>? _roles;
    private string _editFirstName = string.Empty;
    private string _editLastName = string.Empty;
    private string? _editEmail;
    private string? _editPhone;
    private VoiceGroup? _editVoiceGroup;
    private string? _editNotes;
    private Guid? _selectedRoleId;
    private DateTime? _assignFromDate = DateTime.Today;
    private DateTime? _assignToDate;

    protected override async Task OnInitializedAsync()
    {
        await LoadPerson();
        if (TenantContext.CurrentOrganizationId is Guid orgId)
            _roles = await Mediator.Send(new GetRolesQuery(orgId));
    }

    private async Task LoadPerson()
    {
        _person = await Mediator.Send(new GetPersonDetailQuery(PersonId));
        if (_person is not null)
        {
            _editFirstName = _person.FirstName;
            _editLastName = _person.LastName;
            _editEmail = _person.Email;
            _editPhone = _person.Phone;
            _editVoiceGroup = _person.VoiceGroup;
            _editNotes = _person.Notes;
        }
    }

    private async Task SaveChanges()
    {
        var result = await Mediator.Send(new UpdatePersonCommand(
            PersonId, _editFirstName, _editLastName, _editEmail, _editPhone, _editVoiceGroup, _editNotes));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["PersonDetail.Updated"], Severity.Success);
            Navigation.NavigateTo("/people");
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task DeactivatePerson()
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, string.Format(L["PersonDetail.DeactivateConfirm"], _person!.FirstName, _person.LastName) }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["PersonDetail.DeactivateTitle"], parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new DeactivatePersonCommand(PersonId));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["PersonDetail.Deactivated"], Severity.Success);
            await LoadPerson();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task AssignRole()
    {
        if (_selectedRoleId is not Guid roleId || TenantContext.CurrentOrganizationId is not Guid orgId)
            return;

        var result = await Mediator.Send(new AssignRoleCommand(
            PersonId, roleId, _assignFromDate ?? DateTime.UtcNow, _assignToDate, orgId));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["PersonDetail.RoleAssigned"], Severity.Success);
            _selectedRoleId = null;
            _assignToDate = null;
            await LoadPerson();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task EndRoleAssignment(Guid assignmentId)
    {
        var dialog = await DialogService.ShowAsync<EndRoleAssignmentDialog>(L["PersonDetail.EndAssignmentDialogTitle"]);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var endDate = (DateTime)dialogResult.Data!;
        var result = await Mediator.Send(new EndRoleAssignmentCommand(assignmentId, endDate));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["PersonDetail.RoleEnded"], Severity.Success);
            await LoadPerson();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private async Task RemoveRoleAssignment(Guid assignmentId)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, L["PersonDetail.RemoveAssignmentConfirm"] }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>(L["PersonDetail.RemoveAssignmentDialogTitle"], parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled) return;

        var result = await Mediator.Send(new RemoveRoleAssignmentCommand(assignmentId));
        if (result.IsSuccess)
        {
            Snackbar.Add(L["PersonDetail.RoleRemoved"], Severity.Success);
            await LoadPerson();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }

    private string VoiceGroupLabel(VoiceGroup? vg) => vg switch
    {
        null => "—",
        VoiceGroup.None => L["People.VoiceGroupNone"],
        _ => vg.ToString()!
    };
}
