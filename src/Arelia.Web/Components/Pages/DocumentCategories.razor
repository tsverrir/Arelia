@page "/document-categories"
@inherits Arelia.Web.Components.TenantAwarePage
@using Arelia.Application.Documents.Commands
@using Arelia.Application.Documents.Queries
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject ILocalizer L
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["DocumentCategories.Title"]</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">@L.H("DocumentCategories.Title")</MudText>

@if (TenantService.CurrentOrganizationId is null)
{
    <MudAlert Severity="Severity.Warning">@L["Common.SelectOrgFirst"]</MudAlert>
    return;
}

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenCreate())"
           StartIcon="@Icons.Material.Filled.Add" Class="mb-4">
    @L.H("DocumentCategories.Create")
</MudButton>

@if (_categories is not null)
{
    <MudTable Items="_categories" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>@L["Common.Name"]</MudTh>
            <MudTh>@L["DocumentCategories.SortOrder"]</MudTh>
            <MudTh>@L["DocumentCategories.DocumentCount"]</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.SortOrder</MudTd>
            <MudTd>@context.DocumentCount</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEdit(context))" Title="@L["Common.Edit"]" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => StartDelete(context))" Title="@L["Common.Delete"]" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Create / Edit dialog *@
<MudDialog @bind-Visible="_showForm">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editId is null ? L.H("DocumentCategories.CreateTitle") : L.H("DocumentCategories.EditTitle"))</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editName" Label="@L["Common.Name"]" Required="true" />
        <MudNumericField @bind-Value="_editSortOrder" Label="@L["DocumentCategories.SortOrder"]" Min="0" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showForm = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCategory">@L.H("Common.Save")</MudButton>
    </DialogActions>
</MudDialog>

@* Delete dialog *@
<MudDialog @bind-Visible="_showDelete">
    <TitleContent>
        <MudText Typo="Typo.h6">@L.H("DocumentCategories.DeleteTitle")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_deleteTarget is not null && _deleteTarget.DocumentCount > 0)
        {
            <MudText Class="mb-3">
                @string.Format(L["DocumentCategories.DeleteHasDocuments"], _deleteTarget.DocumentCount, _deleteTarget.Name)
            </MudText>
            <MudRadioGroup @bind-Value="_deleteMode">
                <MudRadio Value="DocumentCategoryDeleteMode.UnassignDocuments" Color="Color.Warning">
                    @L["DocumentCategories.DeleteUnassign"]
                </MudRadio>
                <MudRadio Value="DocumentCategoryDeleteMode.MoveDocuments" Color="Color.Info">
                    @L["DocumentCategories.DeleteMove"]
                </MudRadio>
            </MudRadioGroup>
            @if (_deleteMode == DocumentCategoryDeleteMode.MoveDocuments)
            {
                <MudSelect T="Guid?" @bind-Value="_moveToCategoryId" Label="@L["DocumentCategories.MoveTo"]" Class="mt-2">
                    @if (_categories is not null)
                    {
                        @foreach (var cat in _categories.Where(c => c.Id != _deleteTarget.Id))
                        {
                            <MudSelectItem T="Guid?" Value="@cat.Id">@cat.Name</MudSelectItem>
                        }
                    }
                </MudSelect>
            }
        }
        else
        {
            <MudText>@string.Format(L["DocumentCategories.DeleteConfirm"], _deleteTarget?.Name)</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDelete = false)">@L.H("Common.Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ConfirmDelete">@L.H("Common.Delete")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<DocumentCategoryDto>? _categories;

    private bool _showForm;
    private Guid? _editId;
    private string _editName = string.Empty;
    private int _editSortOrder;

    private bool _showDelete;
    private DocumentCategoryDto? _deleteTarget;
    private DocumentCategoryDeleteMode _deleteMode = DocumentCategoryDeleteMode.UnassignDocuments;
    private Guid? _moveToCategoryId;

    protected override async Task OnInitializedAsync()
    {
        RegisterTenantChangeHandler();
        await LoadCategories();
    }

    protected override Task OnTenantChangedAsync() => LoadCategories();

    private async Task LoadCategories()
    {
        if (TenantService.CurrentOrganizationId is not Guid orgId) return;
        _categories = await Mediator.Send(new GetDocumentCategoriesQuery(orgId));
    }

    private void OpenCreate()
    {
        _editId = null;
        _editName = string.Empty;
        _editSortOrder = (_categories?.Count ?? 0) + 1;
        _showForm = true;
    }

    private void OpenEdit(DocumentCategoryDto cat)
    {
        _editId = cat.Id;
        _editName = cat.Name;
        _editSortOrder = cat.SortOrder;
        _showForm = true;
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            Snackbar.Add(L["DocumentCategories.NameRequired"], Severity.Warning);
            return;
        }

        if (_editId is null)
        {
            if (TenantService.CurrentOrganizationId is not Guid orgId) return;
            var result = await Mediator.Send(new CreateDocumentCategoryCommand(_editName.Trim(), _editSortOrder, orgId));
            if (result.IsSuccess)
                Snackbar.Add(L["DocumentCategories.Created"], Severity.Success);
            else
            {
                Snackbar.Add(result.Error!, Severity.Error);
                return;
            }
        }
        else
        {
            var result = await Mediator.Send(new UpdateDocumentCategoryCommand(_editId.Value, _editName.Trim(), _editSortOrder));
            if (result.IsSuccess)
                Snackbar.Add(L["DocumentCategories.Updated"], Severity.Success);
            else
            {
                Snackbar.Add(result.Error!, Severity.Error);
                return;
            }
        }

        _showForm = false;
        await LoadCategories();
    }

    private void StartDelete(DocumentCategoryDto cat)
    {
        _deleteTarget = cat;
        _deleteMode = DocumentCategoryDeleteMode.UnassignDocuments;
        _moveToCategoryId = null;
        _showDelete = true;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;

        if (_deleteMode == DocumentCategoryDeleteMode.MoveDocuments && _moveToCategoryId is null &&
            _deleteTarget.DocumentCount > 0)
        {
            Snackbar.Add(L["DocumentCategories.SelectTarget"], Severity.Warning);
            return;
        }

        var result = await Mediator.Send(new DeleteDocumentCategoryCommand(
            _deleteTarget.Id, _deleteMode, _moveToCategoryId));

        if (result.IsSuccess)
        {
            Snackbar.Add(L["DocumentCategories.Deleted"], Severity.Success);
            _showDelete = false;
            await LoadCategories();
        }
        else
        {
            Snackbar.Add(result.Error!, Severity.Error);
        }
    }
}
